---
import Text from "@/components/shared/AppText.astro";
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";
import { useDictionary } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering } = Astro.props as ComponentProps;
const datasource = rendering?.fields?.data?.datasource;
const externalFields = rendering?.fields?.data?.externalFields ?? {};
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const imageRequired = datasource?.imageRequired?.jsonValue;
const eyebrowOptional = datasource?.eyebrowOptional?.jsonValue;

const pageHeaderTitle = externalFields?.pageHeaderTitle?.jsonValue;
const pageReadTime = externalFields?.pageReadTime?.jsonValue;
const pageDisplayDate = externalFields?.pageDisplayDate?.jsonValue;
const pageAuthor = externalFields?.pageAuthor?.jsonValue;

const dictionary = useDictionary();
const backToNewsLabel = dictionary?.['ARTICLE_HEADER_BACKTONEWS'] || 'Back to News';
const authorLabel = dictionary?.['ARTICLE_HEADER_AUTHOR_LABEL'] || 'Author';

const authorFirstName = pageAuthor?.fields?.personFirstName?.value || '';
const authorLastName = pageAuthor?.fields?.personLastName?.value || '';
const authorFullName = `${authorFirstName} ${authorLastName}`.trim();
const authorImage = pageAuthor?.fields?.personProfileImage?.value?.src;
const authorJobTitle = pageAuthor?.fields?.personJobTitle;

const imageSrc = imageRequired?.value?.src;

const publishedDateISO = pageDisplayDate?.value
  ? new Date(String(pageDisplayDate.value)).toISOString()
  : undefined;

const displayDate = pageDisplayDate?.value
  ? new Date(String(pageDisplayDate.value)).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: 'UTC',
    })
  : '';
---

{datasource ? (
  <astro-article-header>
    <header class="@container article-header relative mb-[86px] overflow-hidden">
      <article itemscope itemtype="https://schema.org/Article">
        <div class="relative z-0 h-auto overflow-hidden bg-black">
          {/* Background Image with blur */}
          {imageSrc && (
            <>
              <div class="absolute inset-0 z-[1] h-[120%] w-[120%] bg-cover bg-center opacity-70">
                <img
                  src={imageSrc}
                  alt=""
                  class="h-full w-full object-cover"
                  aria-hidden="true"
                />
              </div>
              <div class="absolute inset-0 z-[2] backdrop-blur-md"></div>
            </>
          )}
          {/* White bottom bar */}
          <div
            data-component="white-bar"
            class="@xs:h-[125px] @sm:h-[150px] @md:h-[140px] @lg:h-[90px] @xl:h-[180px] absolute bottom-0 z-[3] h-[90px] w-full bg-white"
          ></div>

          {/* Content */}
          <div class="@md:pb-0 relative z-[4] mx-auto flex h-full flex-col justify-between gap-12 p-0 pb-6 pt-[120px]">
            <div class="flex flex-col">
              {/* Back Button */}
              <button
                data-back-btn
                class="absolute left-4 top-[41px] mb-8 inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-default px-8 py-2-5 text-sm font-medium text-white hover:underline"
              >
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
                {backToNewsLabel}
              </button>

              {/* Category Badge */}
              {(eyebrowOptional?.value || isEditing) && (
                <span class="border border-transparent bg-accent text-accent-foreground font-body mx-auto mb-4 inline-block rounded-full px-2.5 py-0.5 text-[14px] font-medium tracking-tighter">
                  <Text field={eyebrowOptional} />
                </span>
              )}

              {/* Title */}
              <Text
                tag="h1"
                class="@md:text-[62px] @md:mb-0 font-heading mx-auto max-w-4xl text-pretty px-6 text-center text-4xl font-normal tracking-tighter text-white"
                field={pageHeaderTitle}
              />

              {/* Read Time and Date */}
              {(pageReadTime?.value || pageDisplayDate?.value || isEditing) && (
                <div class="@md:flex-row @xl:px-8 mb-8 flex flex-col items-center justify-center space-x-2 px-4 text-center text-sm text-white">
                  {(pageReadTime?.value || isEditing) && (
                    <Text tag="span" field={pageReadTime} class="@md:inline-block block text-pretty" />
                  )}
                  {pageReadTime?.value && pageDisplayDate?.value && (
                    <span class="@md:inline-block hidden">&bull;</span>
                  )}
                  {displayDate && (
                    <time datetime={publishedDateISO} itemprop="datePublished" class="@md:inline-block block text-pretty">
                      {displayDate}
                    </time>
                  )}
                </div>
              )}
            </div>

            <div class="@lg:grid @lg:max-w-screen-3xl @lg:mx-auto @lg:w-full @lg:gap-8 @lg:grid-cols-12 mx-6 mb-auto grid grid-cols-2 items-start justify-between">
              {/* Author Info */}
              <div class="@lg:col-span-3 @lg:justify-end @lg:pt-4 @lg:h-[250px] @lg:items-start col-span-1 flex h-auto flex-wrap items-center justify-center gap-4 p-6">
                {pageAuthor && (
                  <div class="grid gap-y-3">
                    <p class="flex min-h-10 flex-col justify-center text-sm text-white">
                      {authorLabel}
                    </p>
                    <div class="flex h-10 w-10 items-center justify-center overflow-hidden rounded-full bg-primary text-primary-foreground">
                      {authorImage ? (
                        <img src={authorImage} alt={authorFullName} class="h-full w-full object-cover" />
                      ) : (
                        <span class="text-xs font-medium">
                          {authorFullName.split(' ').map((n: string) => n[0]).join('')}
                        </span>
                      )}
                    </div>
                    <div class="relative">
                      <p class="text-pretty font-medium text-white">{authorFullName}</p>
                      {authorJobTitle && (
                        <Text tag="p" field={authorJobTitle} class="text-pretty text-sm text-white" />
                      )}
                    </div>
                  </div>
                )}
              </div>

              {/* Share Section - Mobile */}
              <div class="@lg:hidden col-span-1 flex h-auto items-center justify-center gap-4 p-6">
                <p class="text-pretty text-sm font-medium text-white">Share</p>
                <div class="flex gap-2">
                  <button data-share="facebook" class="inline-flex h-10 w-10 items-center justify-center rounded-full text-white hover:bg-white/20" aria-label="Share on Facebook">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                  </button>
                  <button data-share="twitter" class="inline-flex h-10 w-10 items-center justify-center rounded-full text-white hover:bg-white/20" aria-label="Share on Twitter">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
                  </button>
                  <button data-share="linkedin" class="inline-flex h-10 w-10 items-center justify-center rounded-full text-white hover:bg-white/20" aria-label="Share on LinkedIn">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  </button>
                  <button data-share="email" class="inline-flex h-10 w-10 items-center justify-center rounded-full text-white hover:bg-white/20" aria-label="Share via Email">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  </button>
                  <button data-share="copy" class="inline-flex h-10 w-10 items-center justify-center rounded-full text-white hover:bg-white/20" aria-label="Copy link">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
                  </button>
                </div>
              </div>

              {/* Featured Image */}
              <figure class="@lg:col-span-6 relative z-10 col-span-2 mx-auto flex aspect-[16/9] w-full max-w-[800px] justify-center overflow-hidden rounded-[24px]">
                {imageSrc && (
                  <img
                    src={imageSrc}
                    alt={pageHeaderTitle?.value || ''}
                    class="h-full w-full object-cover"
                    loading="eager"
                  />
                )}
              </figure>

              {/* Share Section - Desktop */}
              <div class="@lg:col-span-3 @lg:justify-start @lg:pt-4 @lg:h-[250px] @lg:items-start @lg:flex hidden h-auto items-center justify-center gap-4 p-6">
                <p class="@lg:mt-2 m-0 mb-2 flex items-center justify-center text-pretty text-sm font-medium text-white">
                  Share
                </p>
                <div class="flex flex-col gap-2">
                  <button data-share="facebook" class="inline-flex h-10 w-10 items-center justify-center rounded-full text-white hover:bg-white/20" aria-label="Share on Facebook">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                  </button>
                  <button data-share="twitter" class="inline-flex h-10 w-10 items-center justify-center rounded-full text-white hover:bg-white/20" aria-label="Share on Twitter">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
                  </button>
                  <button data-share="linkedin" class="inline-flex h-10 w-10 items-center justify-center rounded-full text-white hover:bg-white/20" aria-label="Share on LinkedIn">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  </button>
                  <button data-share="email" class="inline-flex h-10 w-10 items-center justify-center rounded-full text-white hover:bg-white/20" aria-label="Share via Email">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  </button>
                  <button data-share="copy" class="inline-flex h-10 w-10 items-center justify-center rounded-full text-white hover:bg-white/20" aria-label="Copy link">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
        {/* Screen reader notification */}
        <div data-copy-notification class="sr-only" aria-live="polite"></div>
      </article>
    </header>
  </astro-article-header>
) : (
  <div class="is-empty-hint">Article Header</div>
)}

<script>
  class AstroArticleHeader extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      // Back button
      this.querySelector('[data-back-btn]')?.addEventListener('click', (e) => {
        e.preventDefault();
        window.history.back();
      });

      // Share buttons
      this.querySelectorAll('[data-share]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const platform = (btn as HTMLElement).dataset.share;
          this.handleShare(platform || '');
        });
      });
    }

    handleShare(platform: string) {
      const url = encodeURIComponent(window.location.href);
      const title = encodeURIComponent(document.title);
      let shareUrl = '';

      switch (platform) {
        case 'facebook':
          shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
          break;
        case 'twitter':
          shareUrl = `https://twitter.com/intent/tweet?url=${url}&text=${title}`;
          break;
        case 'linkedin':
          shareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${url}`;
          break;
        case 'email':
          window.location.href = `mailto:?subject=${title}&body=${url}`;
          return;
        case 'copy':
          navigator.clipboard.writeText(window.location.href).then(() => {
            const notification = this.querySelector('[data-copy-notification]');
            if (notification) {
              notification.textContent = 'Link copied to clipboard';
            }
            // Update copy button icon temporarily
            const copyBtns = this.querySelectorAll('[data-share="copy"]');
            copyBtns.forEach((btn) => {
              btn.setAttribute('aria-label', 'Link copied');
              setTimeout(() => btn.setAttribute('aria-label', 'Copy link'), 3000);
            });
          });
          return;
      }

      window.open(shareUrl, '_blank', 'width=600,height=400');
    }
  }

  customElements.define('astro-article-header', AstroArticleHeader);
</script>
