---
import Text from "@/components/shared/AppText.astro";
import RichTextSDK from "@exdst-sitecore-content-sdk/astro/components/RichText.astro";
import AstroImage from "@exdst-sitecore-content-sdk/astro/components/AstroImage.astro";
import Link from "@exdst-sitecore-content-sdk/astro/components/Link.astro";
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const image = fields?.image;
const title = fields?.title;
const description = fields?.description;
const primaryLink = fields?.primaryLink;
const secondaryLink = fields?.secondaryLink;

const colorScheme = (params as any)?.colorScheme || 'primary';
const isImageRight = (params as any)?.FieldNames === 'ImageRight';
const hasLinks = isEditing || primaryLink?.value?.href || secondaryLink?.value?.href;

const imageBgClass = colorScheme === 'secondary' ? 'bg-accent' : 'bg-primary';
const spriteClass = colorScheme === 'secondary' ? 'bg-primary' : 'bg-accent';

// Layout classes based on variant
const imageFlexClass = isImageRight
  ? 'promo-animated__image @md:flex @md:justify-start @md:order-2 w-full'
  : 'promo-animated__image @md:flex @md:justify-end w-full';
const contentOrderClass = isImageRight
  ? 'promo-animated__content @md:order-1 @md:flex @md:flex-col @md:justify-center min-w-0'
  : 'promo-animated__content @md:flex @md:flex-col @md:justify-center @md:items-start min-w-0';
const bgExtensionClass = isImageRight ? 'left-1/2' : 'right-1/2';
const spriteClipPath = 'clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%);';
const positionClasses = isImageRight
  ? 'group-[.position-center]:mx-auto group-[.position-right]:ml-auto'
  : '';
---

{fields ? (
  <section data-component="PromoAnimated" class="@container">
    <div
      data-class-change
      class={`promo-animated__content-wrapper @md:grid-cols-2 @md:items-center @md:gap-10 @xl:gap-[135px] group grid grid-cols-1 ${params?.styles || ''}`}
    >
      <div class={imageFlexClass}>
        {image && (
          <div class={`@md:max-w-[452px] @xs:mx-0 relative mx-auto aspect-square h-full w-full max-w-[350px] rounded-r-full ${positionClasses}`}>
            <div class={`promo-animated__image-bg-extension absolute bottom-0 top-0 ${bgExtensionClass} w-[100vw] ${imageBgClass}`}></div>
            <div class="relative aspect-square w-full">
              <AstroImage
                field={image}
                class="@md:max-w-[452px] aspect-square w-full rounded-full object-cover"
              />
            </div>
            <div class="pointer-events-none absolute bottom-0 aspect-square h-full w-full rotate-0">
              <div
                class={`promo-animated__sprite h-full w-full rounded-full pointer-events-none ${spriteClass}`}
                style={spriteClipPath}
              ></div>
            </div>
          </div>
        )}
      </div>

      <div class={contentOrderClass}>
        {title && (
          <Text
            tag="h2"
            class={`font-heading @sm:text-5xl @lg:text-6xl -ml-1 mt-6 max-w-[15.5ch] text-4xl font-normal leading-[1.1333] tracking-tighter ${positionClasses}`}
            field={title}
          />
        )}

        {description && (
          <RichTextSDK
            class="text-body text-secondary-foreground prose mt-6 max-w-[51.5ch] text-lg tracking-tight"
            field={description}
          />
        )}

        {hasLinks && (
          <div class="@md:mb-0 mb-6 mt-10 flex w-full flex-wrap gap-2">
            {primaryLink?.value?.href && (
              isEditing ? (
                <Link
                  field={primaryLink}
                  class="inline-flex items-center justify-center rounded-default bg-primary px-8 py-2-5 text-sm font-medium text-primary-foreground hover:bg-primary/90"
                />
              ) : (
                <a
                  href={primaryLink.value.href}
                  class="inline-flex items-center justify-center rounded-default bg-primary px-8 py-2-5 text-sm font-medium text-primary-foreground hover:bg-primary/90"
                >
                  {primaryLink.value.text}
                </a>
              )
            )}
            {secondaryLink?.value?.href && (
              isEditing ? (
                <Link
                  field={secondaryLink}
                  class="inline-flex items-center justify-center rounded-default bg-secondary px-8 py-2-5 text-sm font-medium text-secondary-foreground hover:bg-secondary/80"
                />
              ) : (
                <a
                  href={secondaryLink.value.href}
                  class="inline-flex items-center justify-center rounded-default bg-secondary px-8 py-2-5 text-sm font-medium text-secondary-foreground hover:bg-secondary/80"
                >
                  {secondaryLink.value.text}
                </a>
              )
            )}
          </div>
        )}
      </div>
    </div>
  </section>
) : (
  <div class="is-empty-hint">Promo Animated</div>
)}
