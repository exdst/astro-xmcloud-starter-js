---
import Text from "@exdst-sitecore-content-sdk/astro/components/Text.astro";
import RichTextSDK from "@exdst-sitecore-content-sdk/astro/components/RichText.astro";
import AstroImage from "@exdst-sitecore-content-sdk/astro/components/AstroImage.astro";
import Link from "@exdst-sitecore-content-sdk/astro/components/Link.astro";
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const image = fields?.image;
const title = fields?.title;
const description = fields?.description;
const primaryLink = fields?.primaryLink;
const secondaryLink = fields?.secondaryLink;

const colorScheme = (params as any)?.colorScheme || 'default';
const hasLinks = isEditing || primaryLink?.value?.href || secondaryLink?.value?.href;
---

{fields ? (
  <section data-component="PromoAnimated" class="@container">
    <div
      data-class-change
      class={`promo-animated__content-wrapper @md:grid-cols-2 @md:items-center @md:gap-10 @xl:gap-[135px] group grid grid-cols-1 ${params?.styles || ''}`}
    >
      <div class="promo-animated__image @md:flex @md:justify-end w-full">
        {image && (
          <div class="@md:max-w-[452px] @xs:mx-0 relative mx-auto aspect-square h-full w-full max-w-[350px] rounded-r-full">
            <div class="promo-animated__bg-circle absolute inset-0 right-1/2 rounded-full bg-accent opacity-20"></div>
            <div class="relative aspect-square w-full overflow-hidden rounded-full">
              <AstroImage
                field={image}
                class="@md:max-w-[452px] aspect-square w-full rounded-full object-cover"
              />
            </div>
          </div>
        )}
      </div>

      <div class="promo-animated__content @md:flex @md:flex-col @md:justify-center @md:items-start min-w-0">
        {title && (
          <Text
            tag="h2"
            class="font-heading @sm:text-5xl @lg:text-6xl -ml-1 mt-6 max-w-[15.5ch] text-4xl font-normal leading-[1.1333] tracking-tighter"
            field={title}
          />
        )}

        {description && (
          <RichTextSDK
            class="text-body text-secondary-foreground prose mt-6 max-w-[51.5ch] text-lg tracking-tight"
            field={description}
          />
        )}

        {hasLinks && (
          <div class="@md:mb-0 mb-6 mt-10 flex w-full flex-wrap gap-2">
            {primaryLink?.value?.href && (
              isEditing ? (
                <Link
                  field={primaryLink}
                  class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-primary-foreground hover:bg-primary/90"
                />
              ) : (
                <a
                  href={primaryLink.value.href}
                  class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-primary-foreground hover:bg-primary/90"
                >
                  {primaryLink.value.text}
                </a>
              )
            )}
            {secondaryLink?.value?.href && (
              isEditing ? (
                <Link
                  field={secondaryLink}
                  class="inline-flex items-center justify-center rounded-md bg-secondary px-6 py-3 text-secondary-foreground hover:bg-secondary/90"
                />
              ) : (
                <a
                  href={secondaryLink.value.href}
                  class="inline-flex items-center justify-center rounded-md bg-secondary px-6 py-3 text-secondary-foreground hover:bg-secondary/90"
                >
                  {secondaryLink.value.text}
                </a>
              )
            )}
          </div>
        )}
      </div>
    </div>
  </section>
) : (
  <div class="is-empty-hint">Promo Animated</div>
)}
