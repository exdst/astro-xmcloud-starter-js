---
import Text from "@/components/shared/AppText.astro";
import AstroImage from "@exdst-sitecore-content-sdk/astro/components/AstroImage.astro";
import Link from "@exdst-sitecore-content-sdk/astro/components/Link.astro";
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const titleRequired = fields?.titleRequired;
const descriptionOptional = fields?.descriptionOptional;
const linkOptional = fields?.linkOptional;
const heroVideoOptional1 = fields?.heroVideoOptional1;
const heroImageOptional1 = fields?.heroImageOptional1;
const heroVideoOptional2 = fields?.heroVideoOptional2;
const heroImageOptional2 = fields?.heroImageOptional2;
const heroVideoOptional3 = fields?.heroVideoOptional3;
const heroImageOptional3 = fields?.heroImageOptional3;
const heroVideoOptional4 = fields?.heroVideoOptional4;
const heroImageOptional4 = fields?.heroImageOptional4;

const colorScheme = (params as any)?.colorScheme || 'light';

const colorClasses: Record<string, string> = {
  primary: 'bg-primary text-primary-foreground',
  secondary: 'bg-secondary text-primary',
  tertiary: 'bg-tertiary text-primary',
  dark: 'bg-dark text-primary',
  light: 'bg-light text-primary',
};

const sectionClass = `hero @container py-24 relative w-full overflow-hidden ${colorClasses[colorScheme] || colorClasses.light} ${params?.styles || ''}`;
const descClass = colorScheme === 'primary'
  ? 'text-primary-foreground'
  : 'text-secondary-foreground';
const btnClass = colorScheme === 'primary'
  ? 'text-primary bg-white hover:bg-gray-100'
  : '';

type MediaItem = {
  video: any;
  image: any;
  aspectClass: string;
};

const mediaSections: MediaItem[] = [
  { video: heroVideoOptional1, image: heroImageOptional1, aspectClass: 'aspect-[280/356]' },
  { video: heroVideoOptional2, image: heroImageOptional2, aspectClass: 'aspect-[280/196]' },
  { video: heroVideoOptional3, image: heroImageOptional3, aspectClass: 'aspect-[280/356]' },
  { video: heroVideoOptional4, image: heroImageOptional4, aspectClass: 'aspect-[280/356]' },
];
---

{fields ? (
  <astro-hero>
    <section class={sectionClass}>
      <div class="grid gap-20">
        {/* Hero content */}
        <div class="mx-auto w-full max-w-screen-xl px-4 xl:px-8">
          <div class="@lg:flex-row @lg:items-center @lg:gap-10 flex flex-col items-stretch gap-3">
            {(titleRequired?.value || isEditing) && (
              <Text
                tag="h1"
                field={titleRequired}
                class="font-heading @lg:text-8xl @lg:leading-[90px] basis-1/2 text-5xl font-normal leading-[60px]"
              />
            )}
            <div class="@lg:gap-10 flex basis-1/2 flex-col gap-8">
              {(descriptionOptional?.value || isEditing) && (
                <Text
                  tag="p"
                  class={`font-body line-height-[26px] text-medium font-base @md:text-xl text-lg ${descClass}`}
                  field={descriptionOptional}
                />
              )}
              {linkOptional?.value?.href && (
                <div>
                  {isEditing ? (
                    <Link field={linkOptional} class={`inline-block rounded-md px-6 py-3 font-medium ${btnClass}`} />
                  ) : (
                    <a href={linkOptional.value.href} class={`inline-block rounded-md bg-primary px-6 py-3 font-medium text-primary-foreground hover:bg-primary/90 ${btnClass}`}>
                      {linkOptional.value.text}
                    </a>
                  )}
                </div>
              )}
            </div>
          </div>
        </div>
        {/* Hero media sections */}
        <div class="relative flex items-center justify-center overflow-x-hidden">
          <div class="@lg:gap-8 @lg:min-w-[120%] mx-auto flex min-w-[110%] items-start gap-4 px-4">
            {mediaSections.map((section) => (
              <div class="shrink-0 grow-0 basis-1/4">
                <div class={`${section.aspectClass} relative overflow-hidden rounded-lg`}>
                  {section.video?.value?.href ? (
                    <video
                      class="absolute inset-0 h-full w-full object-cover"
                      src={section.video.value.href}
                      muted
                      loop
                      playsinline
                      autoplay
                      data-hero-video
                    />
                  ) : section.image?.value?.src ? (
                    <img
                      src={section.image.value.src}
                      alt={section.image.value.alt || ''}
                      class="absolute inset-0 h-full w-full object-cover"
                      loading="lazy"
                    />
                  ) : null}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
      {/* Play/Pause button */}
      <button
        data-play-pause
        class="absolute bottom-2 right-2 inline-flex items-center justify-center p-2 hover:opacity-80"
        aria-label="Pause Ambient Video"
      >
        <svg data-pause-icon class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <rect x="6" y="4" width="4" height="16" />
          <rect x="14" y="4" width="4" height="16" />
        </svg>
        <svg data-play-icon class="hidden h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <polygon points="5,3 19,12 5,21" />
        </svg>
      </button>
    </section>
  </astro-hero>
) : (
  <div class="is-empty-hint">Hero</div>
)}

<script>
  class AstroHero extends HTMLElement {
    private isPlaying = true;
    private videos: HTMLVideoElement[];
    private playPauseBtn: HTMLButtonElement | null;
    private pauseIcon: SVGElement | null;
    private playIcon: SVGElement | null;

    constructor() {
      super();
      this.videos = Array.from(this.querySelectorAll('[data-hero-video]'));
      this.playPauseBtn = this.querySelector('[data-play-pause]');
      this.pauseIcon = this.querySelector('[data-pause-icon]');
      this.playIcon = this.querySelector('[data-play-icon]');
    }

    connectedCallback() {
      // Check prefers-reduced-motion
      const mediaQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
      if (mediaQuery.matches) {
        this.pauseAll();
        this.playPauseBtn?.remove();
        return;
      }

      this.playPauseBtn?.addEventListener('click', () => {
        this.isPlaying = !this.isPlaying;
        if (this.isPlaying) {
          this.playAll();
        } else {
          this.pauseAll();
        }
        this.updateIcon();
      });
    }

    pauseAll() {
      this.isPlaying = false;
      this.videos.forEach((v) => v.pause());
      this.updateIcon();
    }

    playAll() {
      this.isPlaying = true;
      this.videos.forEach((v) => v.play());
      this.updateIcon();
    }

    updateIcon() {
      if (this.pauseIcon && this.playIcon) {
        this.pauseIcon.classList.toggle('hidden', !this.isPlaying);
        this.playIcon.classList.toggle('hidden', this.isPlaying);
      }
      if (this.playPauseBtn) {
        this.playPauseBtn.setAttribute(
          'aria-label',
          this.isPlaying ? 'Pause Ambient Video' : 'Play Ambient Video'
        );
      }
    }
  }

  customElements.define('astro-hero', AstroHero);
</script>
