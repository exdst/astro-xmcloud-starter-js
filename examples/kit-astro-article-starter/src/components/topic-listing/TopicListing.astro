---
import Text from "@exdst-sitecore-content-sdk/astro/components/Text.astro";
import Link from "@exdst-sitecore-content-sdk/astro/components/Link.astro";
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const datasource = rendering?.fields?.data?.datasource;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const title = datasource?.title?.jsonValue;
const children = datasource?.children?.results ?? [];
const backgroundTheme = (params as any)?.backgroundTheme;
---

{datasource ? (
  <div
    class="@container bg-primary text-primary-foreground relative overflow-hidden py-24 md:pb-[128px] md:pt-28"
    data-class-change
  >
    <div class="relative z-20 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center gap-16 text-center md:gap-24">
        <div class="flex max-w-4xl flex-col items-center gap-4">
          {title && (
            <Text
              tag="h2"
              field={title}
              class="font-heading @sm:text-5xl @md:text-6xl @lg:text-7xl text-4xl font-semibold leading-tight tracking-normal text-white"
            />
          )}
        </div>
        {children.length > 0 && (
          <div class="flex flex-wrap items-center justify-center gap-6">
            {children.map((topic: any) => {
              const linkField = topic?.link?.jsonValue;
              const href = linkField?.value?.href;
              const text = linkField?.value?.text;

              if (!isEditing && !href) return null;

              return isEditing ? (
                <Link
                  field={linkField}
                  class="inline-flex items-center justify-center rounded-full border border-white/30 bg-white/10 px-6 py-3 text-sm font-medium text-white backdrop-blur-sm transition-colors hover:bg-white/20"
                />
              ) : (
                <a
                  href={href}
                  class="inline-flex items-center justify-center rounded-full border border-white/30 bg-white/10 px-6 py-3 text-sm font-medium text-white backdrop-blur-sm transition-colors hover:bg-white/20"
                >
                  {text || 'Add link'}
                </a>
              );
            })}
          </div>
        )}
      </div>
    </div>
  </div>
) : (
  <div class="is-empty-hint">Topic Listing</div>
)}
