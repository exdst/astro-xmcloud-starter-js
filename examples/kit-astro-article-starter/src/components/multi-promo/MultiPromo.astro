---
import Text from "@exdst-sitecore-content-sdk/astro/components/Text.astro";
import RichTextSDK from "@exdst-sitecore-content-sdk/astro/components/RichText.astro";
import Link from "@exdst-sitecore-content-sdk/astro/components/Link.astro";
import AstroImage from "@exdst-sitecore-content-sdk/astro/components/AstroImage.astro";
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const datasource = rendering?.fields?.data?.datasource;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const title = datasource?.title?.jsonValue;
const description = datasource?.description?.jsonValue;
const children = datasource?.children?.results ?? [];
const numColumns = (params as any)?.numColumns || '3';

const hasPagesPositionStyles = params?.styles
  ? params.styles.includes('position-')
  : false;

const containerClass = [
  'mx-auto my-8 max-w-screen-xl md:my-16',
  !hasPagesPositionStyles ? 'position-left' : '',
  params?.styles || '',
].filter(Boolean).join(' ');

const itemBasis: Record<string, string> = {
  '3': 'sm:basis-[45%] md:basis-[31%]',
  '4': 'sm:basis-[45%] md:basis-[31%] xl:basis-[23%]',
};
---

{datasource ? (
  <div data-component="MultiPromo" class={containerClass}>
    <div class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between xl:gap-20">
      {title && (
        <div class="basis-full xl:basis-1/2">
          <Text
            tag="h2"
            field={title}
            class="font-heading -ml-1 max-w-[20ch] text-pretty text-4xl font-normal leading-[1.1333] tracking-tighter sm:text-5xl md:max-w-[17.5ch] lg:text-6xl"
          />
        </div>
      )}
      {description && (
        <div class="basis-full xl:basis-1/2">
          <RichTextSDK
            class="text-body prose mt-6 max-w-[51.5ch] text-pretty text-lg leading-[1.444] tracking-tight"
            field={description}
          />
        </div>
      )}
    </div>
    {children.length > 0 && (
      <div class="my-12 grid grid-cols-1 gap-8 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3">
        {children.map((item: any) => {
          const itemTitle = item?.heading?.jsonValue;
          const itemImage = item?.image?.jsonValue;
          const itemLink = item?.link?.jsonValue;
          return (
            <div class="flex flex-col">
              {(isEditing || itemImage?.value?.src) && (
                <div class="aspect-[131/121] w-full mb-7 overflow-hidden rounded-3xl">
                  <AstroImage
                    field={itemImage}
                    class="aspect-[131/121] w-full object-cover"
                  />
                </div>
              )}
              {(isEditing || itemTitle?.value) && (
                <Text
                  tag="h3"
                  field={itemTitle}
                  class="font-heading text-2xl font-medium leading-snug tracking-tighter"
                />
              )}
              {(isEditing || itemLink?.value?.href) && (
                <Link
                  field={itemLink}
                  class="mt-4 text-sm font-normal hover:underline"
                />
              )}
            </div>
          );
        })}
      </div>
    )}
  </div>
) : (
  <div class="is-empty-hint">Multi Promo</div>
)}
