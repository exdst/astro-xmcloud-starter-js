---
interface Props {
  iconName: string;
  class?: string;
  isAriaHidden?: boolean;
  altText?: string;
}

const { iconName, class: className = '', isAriaHidden = true, altText } = Astro.props;

const ariaAttrs: Record<string, any> = {};
if (isAriaHidden) ariaAttrs['aria-hidden'] = 'true';
if (altText) ariaAttrs['aria-label'] = altText;
---

{iconName === 'arrow-left' && (
  <svg class={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" width="24" height="24" {...ariaAttrs}>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
  </svg>
)}

