            <ul class="grid md:grid-cols-4 gap-x-8 gap-y-12 my-8">
              {features.map((f) => (
                <li class="flex flex-col items-center gap-4">
                  {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="w-[30px] h-[30px]" loading="lazy" />}
                  <h3 class="text-sm font-semibold text-center">{f.featureHeading}</h3>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  ) :

  (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class="grid md:grid-cols-2 items-center gap-x-20 gap-y-12">
          <div>
            {d.tagLine && <p class="font-semibold mb-4">{d.tagLine}</p>}
            <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
            {d.body && <div class="text-lg" set:html={d.body} />}
            <div class="grid md:grid-cols-2 gap-x-8 gap-y-12 my-8">
              {features.map((f) => (
                <div>
                  {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="mb-4 w-12 h-12" loading="lazy" />}
                  <h3 class="text-xl font-bold mb-4">{f.featureHeading}</h3>
                  <p>{f.featureDescription}</p>
                </div>
              ))}
            </div>
            <div class="flex flex-wrap gap-6 mt-4">
              {d.link1.href && <a href={d.link1.href} target={d.link1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{d.link1.text}</a>}
              {d.link2.href && <a href={d.link2.href} target={d.link2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{d.link2.text}</a>}
            </div>
          </div>
          <div>
            {d.image.src && <img src={d.image.src} alt={d.image.alt} class="aspect-square object-cover" loading="lazy" />}
          </div>
        </div>
      </div>
    </section>
  )
) : (
  <div class="is-empty-hint">Features Section</div>
)}

<script>
  // --- Tab switching (FeaturesSection17, FeaturesSection18) ---
  document.querySelectorAll('[data-feature-tabs]').forEach((tabRoot) => {
    const triggers = tabRoot.querySelectorAll<HTMLButtonElement>('[data-tab-trigger]');
    const panels = tabRoot.querySelectorAll<HTMLElement>('[data-tab-panel]');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const id = trigger.getAttribute('data-tab-trigger')!;
        triggers.forEach((t) => {
          t.setAttribute('aria-selected', t === trigger ? 'true' : 'false');
          // For vertical tabs (section17): toggle border-e-transparent
          if (t.classList.contains('md:border-e')) {
            t.classList.toggle('md:border-e-transparent', t === trigger);
          }
          // For horizontal tabs (section18): toggle border color
          if (t.classList.contains('border-b-2')) {
            t.classList.toggle('border-current', t === trigger);
            t.classList.toggle('border-transparent', t !== trigger);
          }
        });
        panels.forEach((p) => {
          p.classList.toggle('hidden', p.getAttribute('data-tab-panel') !== id);
        });
      });
    });
  });

  // --- Click-to-switch panels (FeaturesSection12) ---
  document.querySelectorAll('[data-feature-click-panels]').forEach((root) => {
    const triggers = root.querySelectorAll<HTMLElement>('[data-click-panel-trigger]');
    const images = root.querySelectorAll<HTMLElement>('[data-click-panel-image]');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const id = trigger.getAttribute('data-click-panel-trigger')!;
        triggers.forEach((t) => {
          t.classList.toggle('border-transparent', t.getAttribute('data-click-panel-trigger') !== id);
          t.classList.toggle('border-s-2', true);
        });
        images.forEach((img) => {
          const isActive = img.getAttribute('data-click-panel-image') === id;
          img.classList.toggle('opacity-0', !isActive);
          img.classList.toggle('opacity-100', isActive);
        });
      });
    });
  });

  // --- Accordion + image switching (FeaturesSection13, FeaturesSection21) ---
  document.querySelectorAll('[data-feature-accordion-panels]').forEach((root) => {
    const accordions = root.querySelectorAll<HTMLDetailsElement>('[data-feature-accordion-tab]');
    const images = root.querySelectorAll<HTMLElement>('[data-accordion-panel-image]');
    const bars = root.querySelectorAll<HTMLElement>('[data-accordion-bar]');

    accordions.forEach((details) => {
      details.addEventListener('toggle', () => {
        if (!details.open) return;
        const id = details.getAttribute('data-feature-accordion-tab')!;

        // Close other accordions
        accordions.forEach((d) => {
          if (d !== details) d.open = false;
          d.classList.toggle('opacity-25', d !== details);
          d.classList.remove('opacity-25');
        });
        // Set opacity on non-active items
        accordions.forEach((d) => {
          if (d !== details) {
            d.style.opacity = '0.25';
          } else {
            d.style.opacity = '1';
          }
        });

        // Switch images
        images.forEach((img) => {
          const isActive = img.getAttribute('data-accordion-panel-image') === id;
          img.classList.toggle('opacity-0', !isActive);
          img.classList.toggle('opacity-100', isActive);
        });

        // Toggle side bars (FeaturesSection21)
        bars.forEach((bar) => {
          const isActive = bar.getAttribute('data-accordion-bar') === id;
          bar.classList.toggle('opacity-0', !isActive);
          bar.classList.toggle('opacity-100', isActive);
        });
      });
    });
  });

  // --- Horizontal accordion (FeaturesSection19) ---
  document.querySelectorAll('[data-feature-horizontal-accordion]').forEach((root) => {
    const triggers = root.querySelectorAll<HTMLButtonElement>('[data-h-accordion-trigger]');
    const contents = root.querySelectorAll<HTMLElement>('[data-h-accordion-content]');
    const items = root.querySelectorAll<HTMLElement>('[data-h-accordion-item]');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const id = trigger.getAttribute('data-h-accordion-trigger')!;
        contents.forEach((c) => {
          c.classList.toggle('hidden', c.getAttribute('data-h-accordion-content') !== id);
        });
        items.forEach((item) => {
          item.classList.toggle('md:basis-full', item.getAttribute('data-h-accordion-item') === id);
        });
      });
    });
  });

  // --- Carousel (FeaturesSection23, FeaturesSection24) ---
  class AstroFeaturesCarousel extends HTMLElement {
    connectedCallback() {
      const track = this.querySelector<HTMLElement>('[data-carousel-track]');
      const prevBtn = this.querySelector<HTMLButtonElement>('[data-carousel-prev]');
      const nextBtn = this.querySelector<HTMLButtonElement>('[data-carousel-next]');
      const slides = this.querySelectorAll<HTMLElement>('[data-carousel-slide]');
      if (!track || !prevBtn || !nextBtn || slides.length === 0) return;

      let current = 0;
      const getVisible = () => {
        const w = window.innerWidth;
        if (w >= 1024) return 3;
        if (w >= 768) return 2;
        return 1;
      };

      const update = () => {
        const visible = getVisible();
        const max = Math.max(0, slides.length - visible);
        current = Math.min(current, max);
        const pct = (current / slides.length) * 100;
        track.style.transform = `translateX(-${pct}%)`;
      };

      prevBtn.addEventListener('click', () => { current = Math.max(0, current - 1); update(); });
      nextBtn.addEventListener('click', () => { const visible = getVisible(); current = Math.min(slides.length - visible, current + 1); update(); });
      window.addEventListener('resize', update);
    }
  }
  if (!customElements.get('astro-features-carousel')) {
    customElements.define('astro-features-carousel', AstroFeaturesCarousel);
  }

  // --- IntersectionObserver for fade-in (FeaturesSection21, 23, 24) ---
  const fadeSections = document.querySelectorAll('[data-fade-section]');
  if (fadeSections.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            // Also reveal child fade-side/fade-up elements
            entry.target.querySelectorAll('.fade-section').forEach((el) => el.classList.add('is-visible'));
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    fadeSections.forEach((el) => observer.observe(el));
  }
</script>

<style>
  .fade-section {
    opacity: 0;
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .fade-up {
    transform: translateY(20px);
  }
  .fade-side {
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .fade-section.is-visible {
    opacity: 1;
    transform: translateX(0) translateY(0);
  }
</style>
