---
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const variant = params?.FieldNames || params?.Variant || 'Default';
const styles = params?.styles || '';
const id = params?.RenderingIdentifier || '';

const datasource = fields?.data?.datasource;

const sf = (field: any) => field?.jsonValue?.value ?? '';
const si = (field: any) => ({ src: field?.jsonValue?.value?.src ?? '', alt: field?.jsonValue?.value?.alt ?? '' });
const sl = (field: any) => ({ href: field?.jsonValue?.value?.href ?? '', text: field?.jsonValue?.value?.text ?? '', target: field?.jsonValue?.value?.target ?? '' });

const features = (datasource?.children?.results ?? []).map((f: any) => ({
  id: f.id || '',
  featureTagLine: sf(f.featureTagLine),
  featureHeading: sf(f.featureHeading),
  featureDescription: sf(f.featureDescription),
  featureIcon: si(f.featureIcon),
  featureImage: si(f.featureImage),
  featureLink1: sl(f.featureLink1),
  featureLink2: sl(f.featureLink2),
}));

const d = {
  heading: sf(datasource?.heading),
  tagLine: sf(datasource?.tagLine),
  body: sf(datasource?.body),
  image: si(datasource?.image),
  link1: sl(datasource?.link1),
  link2: sl(datasource?.link2),
};

const firstId = features[0]?.id || '';
---

{datasource ? (
  variant === 'Default' || variant === 'FeaturesSection1' || variant === 'FeaturesSection2' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class="grid md:grid-cols-2 items-center gap-x-20 gap-y-12">
          <div>
            {d.tagLine && <p class="font-semibold mb-4">{d.tagLine}</p>}
            <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
            {d.body && <div class="text-lg" set:html={d.body} />}
            <div class={`${variant === 'FeaturesSection2' ? 'grid gap-y-4' : 'grid md:grid-cols-2 gap-x-8 gap-y-12'} my-8`}>
              {features.map((f) => (
                variant === 'FeaturesSection1' ? (
                  <div class="flex gap-4 items-start">
                    {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="shrink-0 w-[30px] h-[30px]" loading="lazy" />}
                    <div>
                      <h3 class="text-xl font-bold mb-4">{f.featureHeading}</h3>
                      <p>{f.featureDescription}</p>
                    </div>
                  </div>
                ) : variant === 'FeaturesSection2' ? (
                  <div>
                    <div class="flex gap-4 items-start">
                      {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="w-5 h-5" loading="lazy" />}
                      <h3>{f.featureDescription}</h3>
                    </div>
                  </div>
                ) : (
                  <div>
                    {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="mb-4 w-12 h-12" loading="lazy" />}
                    <h3 class="text-xl font-bold mb-4">{f.featureHeading}</h3>
                    <p>{f.featureDescription}</p>
                  </div>
                )
              ))}
            </div>
            <div class="flex flex-wrap gap-6 mt-4">
              {d.link1.href && <a href={d.link1.href} target={d.link1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{d.link1.text}</a>}
              {d.link2.href && <a href={d.link2.href} target={d.link2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{d.link2.text}</a>}
            </div>
          </div>
          <div>
            {d.image.src && <img src={d.image.src} alt={d.image.alt} class="aspect-square object-cover" loading="lazy" />}
          </div>
        </div>
      </div>
    </section>
  ) :

  variant === 'FeaturesSection3' || variant === 'FeaturesSection4' || variant === 'FeaturesSection5' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class="grid md:grid-cols-2 gap-x-20 gap-y-4">
          <div>
            {d.tagLine && <p class="font-semibold mb-4">{d.tagLine}</p>}
            <h2 class="text-5xl font-bold">{d.heading}</h2>
          </div>
          <div>
            {d.body && <div class="text-lg" set:html={d.body} />}
            <div class={`${variant === 'FeaturesSection5' ? 'grid gap-y-4' : 'grid md:grid-cols-2 gap-x-8 gap-y-12'} my-8`}>
              {features.map((f) => (
                variant === 'FeaturesSection4' ? (
                  <div class="flex gap-4 items-start">
                    {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="shrink-0 w-[30px] h-[30px]" loading="lazy" />}
                    <div>
                      <h3 class="text-xl font-bold mb-4">{f.featureHeading}</h3>
                      <p>{f.featureDescription}</p>
                    </div>
                  </div>
                ) : variant === 'FeaturesSection5' ? (
                  <div>
                    <div class="flex gap-4 items-start">
                      {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="w-5 h-5" loading="lazy" />}
                      <h3>{f.featureDescription}</h3>
                    </div>
                  </div>
                ) : (
                  <div>
                    {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="mb-4 w-12 h-12" loading="lazy" />}
                    <h3 class="text-xl font-bold mb-4">{f.featureHeading}</h3>
                    <p>{f.featureDescription}</p>
                  </div>
                )
              ))}
            </div>
            <div class="flex flex-wrap gap-6 mt-4">
              {d.link1.href && <a href={d.link1.href} target={d.link1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{d.link1.text}</a>}
              {d.link2.href && <a href={d.link2.href} target={d.link2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{d.link2.text}</a>}
            </div>
          </div>
        </div>
        {d.image.src && <img src={d.image.src} alt={d.image.alt} class="w-full aspect-16/9 object-cover mt-20" loading="lazy" />}
      </div>
    </section>
  ) :

  variant === 'FeaturesSection6' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class="grid md:grid-cols-2 gap-x-20 gap-y-4">
          <div>
            {d.tagLine && <p class="font-semibold mb-4">{d.tagLine}</p>}
            <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
            {d.body && <div class="text-lg mb-8" set:html={d.body} />}
            <div class="flex flex-wrap gap-6 mt-4">
              {d.link1.href && <a href={d.link1.href} target={d.link1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{d.link1.text}</a>}
              {d.link2.href && <a href={d.link2.href} target={d.link2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{d.link2.text}</a>}
            </div>
          </div>
          <div>
            <div class="grid gap-y-4">
              {features.map((f, i) => (
                <div class="flex gap-8 py-10">
                  <div class="shrink-0 relative">
                    {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="shrink-0 w-10 h-10" loading="lazy" />}
                    {i !== features.length - 1 && <span class="absolute top-18 bottom-0 left-[calc(50%-1px)] w-[2px] h-full bg-black"></span>}
                  </div>
                  <div>
                    <h3 class="text-xl font-bold mb-4">{f.featureHeading}</h3>
                    <p>{f.featureDescription}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  ) :

  variant === 'FeaturesSection7' || variant === 'FeaturesSection8' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class="grid md:grid-cols-2 gap-16">
          {features.map((f) => (
            variant === 'FeaturesSection8' ? (
              <div>
                {f.featureImage.src && <img src={f.featureImage.src} alt={f.featureImage.alt} class="aspect-3/2 w-full object-cover mb-4" loading="lazy" />}
                <p class="font-semibold mb-4">{f.featureTagLine}</p>
                <h3 class="text-4xl font-bold mb-6">{f.featureHeading}</h3>
                <p class="mb-6">{f.featureDescription}</p>
                <div class="flex flex-wrap gap-6 mt-4">
                  {f.featureLink1.href && <a href={f.featureLink1.href} target={f.featureLink1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{f.featureLink1.text}</a>}
                  {f.featureLink2.href && <a href={f.featureLink2.href} target={f.featureLink2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{f.featureLink2.text}</a>}
                </div>
              </div>
            ) : (
              <div>
                {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="mb-4 w-12 h-12" loading="lazy" />}
                <h3 class="text-4xl font-bold mb-6">{f.featureHeading}</h3>
                <p class="mb-6">{f.featureDescription}</p>
                <div class="flex flex-wrap gap-6 mt-4">
                  {f.featureLink1.href && <a href={f.featureLink1.href} target={f.featureLink1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{f.featureLink1.text}</a>}
                  {f.featureLink2.href && <a href={f.featureLink2.href} target={f.featureLink2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{f.featureLink2.text}</a>}
                </div>
              </div>
            )
          ))}
        </div>
      </div>
    </section>
  ) :

  variant === 'FeaturesSection9' || variant === 'FeaturesSection10' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class="grid md:grid-cols-2 gap-x-20 gap-y-12">
          <div>
            {d.image.src && <img src={d.image.src} alt={d.image.alt} class="w-full h-full object-cover" loading="lazy" />}
          </div>
          <div class={`${variant === 'FeaturesSection9' ? 'grid md:grid-cols-2 gap-x-8 gap-y-12' : 'grid gap-x-8 gap-y-12'} py-8`}>
            {features.map((f) => (
              variant === 'FeaturesSection10' ? (
                <div class="flex gap-4 items-start">
                  {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="shrink-0 w-[30px] h-[30px]" loading="lazy" />}
                  <div>
                    <h3 class="text-xl font-bold mb-4">{f.featureHeading}</h3>
                    <p>{f.featureDescription}</p>
                    <div class="flex flex-wrap gap-6 mt-4">
                      {f.featureLink1.href && <a href={f.featureLink1.href} target={f.featureLink1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{f.featureLink1.text}</a>}
                      {f.featureLink2.href && <a href={f.featureLink2.href} target={f.featureLink2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{f.featureLink2.text}</a>}
                    </div>
                  </div>
                </div>
              ) : (
                <div>
                  {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="mb-4 w-12 h-12" loading="lazy" />}
                  <h3 class="text-xl font-bold mb-4">{f.featureHeading}</h3>
                  <p>{f.featureDescription}</p>
                  <div class="flex flex-wrap gap-6 mt-4">
                    {f.featureLink1.href && <a href={f.featureLink1.href} target={f.featureLink1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{f.featureLink1.text}</a>}
                    {f.featureLink2.href && <a href={f.featureLink2.href} target={f.featureLink2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{f.featureLink2.text}</a>}
                  </div>
                </div>
              )
            ))}
          </div>
        </div>
      </div>
    </section>
  ) :

  variant === 'FeaturesSection11' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class="max-w-3xl mx-auto text-center">
          {d.tagLine && <p class="font-semibold mb-4">{d.tagLine}</p>}
          <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
          {d.body && <div class="text-lg" set:html={d.body} />}
        </div>
        <div class="grid grid-flow-dense md:grid-cols-3 gap-x-20 gap-y-12 my-12">
          {d.image.src && <img src={d.image.src} alt={d.image.alt} class="w-full h-full object-cover md:row-span-2 md:col-start-2" loading="lazy" />}
          {features.map((f) => (
            <div class="flex flex-col items-center text-center my-4">
              {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="mb-4 w-12 h-12" loading="lazy" />}
              <h3 class="text-xl font-bold mb-4">{f.featureHeading}</h3>
              <p>{f.featureDescription}</p>
            </div>
          ))}
        </div>
        <div class="flex justify-center">
          <div class="flex flex-wrap gap-6 mt-4">
            {d.link1.href && <a href={d.link1.href} target={d.link1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{d.link1.text}</a>}
            {d.link2.href && <a href={d.link2.href} target={d.link2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{d.link2.text}</a>}
          </div>
        </div>
      </div>
    </section>
  ) :

  variant === 'FeaturesSection12' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change data-feature-click-panels data-active-id={firstId}>
      <div class="container mx-auto">
        <div class="grid md:grid-cols-2 gap-x-20 gap-y-12">
          <div>
            {d.tagLine && <p class="font-semibold mb-4">{d.tagLine}</p>}
            <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
            {d.body && <div class="text-lg" set:html={d.body} />}
            <div class="grid my-8">
              {features.map((f) => (
                <div data-click-panel-trigger={f.id} class={`ps-6 py-4 cursor-pointer border-s-2 ${f.id !== firstId ? 'border-transparent' : ''}`}>
                  <h3 class="text-2xl font-bold mb-2">{f.featureHeading}</h3>
                  <p>{f.featureDescription}</p>
                </div>
              ))}
            </div>
            <div class="flex flex-wrap gap-6 mt-4">
              {d.link1.href && <a href={d.link1.href} target={d.link1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{d.link1.text}</a>}
              {d.link2.href && <a href={d.link2.href} target={d.link2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{d.link2.text}</a>}
            </div>
          </div>
          <div class="relative min-h-80">
            {features.map((f) => (
              <div data-click-panel-image={f.id} class={`absolute inset-0 transition-opacity duration-300 ${f.id !== firstId ? 'opacity-0' : 'opacity-100'}`}>
                {f.featureImage.src && <img src={f.featureImage.src} alt={f.featureImage.alt} class="w-full h-full object-cover" loading="lazy" />}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  ) :

  variant === 'FeaturesSection13' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change data-feature-accordion-panels data-active-id={firstId}>
      <div class="container mx-auto">
        <div class="max-w-3xl mx-auto text-center">
          {d.tagLine && <p class="font-semibold mb-4">{d.tagLine}</p>}
          <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
          {d.body && <div class="text-lg mb-6" set:html={d.body} />}
          <div class="flex justify-center">
            <div class="flex flex-wrap gap-6 mt-4">
              {d.link1.href && <a href={d.link1.href} target={d.link1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{d.link1.text}</a>}
              {d.link2.href && <a href={d.link2.href} target={d.link2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{d.link2.text}</a>}
            </div>
          </div>
        </div>
        <div class="grid md:grid-cols-2 items-center gap-x-20 gap-y-12 mt-20">
          <div class="relative aspect-square">
            {features.map((f) => (
              <div data-accordion-panel-image={f.id} class={`absolute inset-0 transition-opacity duration-300 ${f.id !== firstId ? 'opacity-0' : 'opacity-100'}`}>
                {f.featureImage.src && <img src={f.featureImage.src} alt={f.featureImage.alt} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />}
              </div>
            ))}
          </div>
          <div class="grid my-8">
            {features.map((f) => (
              <details data-feature-accordion-tab={f.id} class={`group py-4 border-b transition-opacity duration-300 ${f.id !== firstId ? 'opacity-25' : ''}`} open={f.id === firstId}>
                <summary class="cursor-pointer list-none hover:no-underline">
                  <div class="flex gap-6 items-center justify-between">
                    <div class="flex gap-6">
                      {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class="shrink-0 w-8 h-8" loading="lazy" />}
                      <h3 class="text-3xl font-bold mb-2">{f.featureHeading}</h3>
                    </div>
                    <svg class="shrink-0 w-4 h-4 transition-transform duration-200 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                  </div>
                </summary>
                <p class="ps-14 pt-2">{f.featureDescription}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>
  ) :

  variant === 'FeaturesSection14' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class="max-w-3xl mx-auto text-center">
          {d.tagLine && <p class="font-semibold mb-4">{d.tagLine}</p>}
          <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
          {d.body && <div class="text-lg mb-6" set:html={d.body} />}
          <div class="flex justify-center">
            <div class="flex flex-wrap gap-6 mt-4">
              {d.link1.href && <a href={d.link1.href} target={d.link1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{d.link1.text}</a>}
              {d.link2.href && <a href={d.link2.href} target={d.link2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{d.link2.text}</a>}
            </div>
          </div>
        </div>
        <div class="flex flex-col md:flex-row gap-8 mt-12">
          {features.map((f) => (
            <div class={`relative flex flex-col justify-center ${features.length < 3 ? 'p-12' : 'p-8'} text-white`}>
              {f.featureImage.src && <img src={f.featureImage.src} alt={f.featureImage.alt} class="absolute w-full h-full object-cover inset-0 brightness-50 z-10" loading="lazy" />}
              <div class="relative z-20">
                {f.featureIcon.src && <img src={f.featureIcon.src} alt={f.featureIcon.alt} class={`inline-block ${features.length < 3 ? 'mb-6' : 'mb-4'} w-12 h-12`} loading="lazy" />}
                <h3 class={`${features.length < 3 ? 'text-4xl' : 'text-3xl'} font-bold ${features.length < 3 ? 'mb-6' : 'mb-4'}`}>{f.featureHeading}</h3>
                <p class={features.length < 3 ? 'mb-6' : ''}>{f.featureDescription}</p>
                <div class="flex flex-wrap gap-6 mt-4">
                  {f.featureLink1.href && <a href={f.featureLink1.href} target={f.featureLink1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{f.featureLink1.text}</a>}
                  {f.featureLink2.href && <a href={f.featureLink2.href} target={f.featureLink2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{f.featureLink2.text}</a>}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ) :

  variant === 'FeaturesSection15' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class="max-w-3xl mx-auto text-center">
          {d.tagLine && <p class="font-semibold mb-4">{d.tagLine}</p>}
          <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
          {d.body && <div class="text-lg mb-6" set:html={d.body} />}
          <div class="flex justify-center">
            <div class="flex flex-wrap gap-6 mt-4">
              {d.link1.href && <a href={d.link1.href} target={d.link1.target || undefined} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{d.link1.text}</a>}
              {d.link2.href && <a href={d.link2.href} target={d.link2.target || undefined} class="inline-flex items-center px-0 text-sm font-medium underline-offset-4 hover:underline">{d.link2.text}</a>}
            </div>
          </div>
        </div>
        <div class="grid grid-flow-dense gap-8 md:grid-cols-4 mt-12">
          {features.map((f, i) => {
            const isLarge = i === 0 || i === 3;
            return (
