---
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";
import { FeaturesSectionIsland } from "./FeaturesSection.tsx";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const variant = params?.FieldNames || params?.Variant || 'Default';
const styles = params?.styles || '';
const id = params?.RenderingIdentifier || '';

const datasource = fields?.data?.datasource;

const sf = (field: any) => field?.jsonValue?.value ?? '';
const si = (field: any) => ({ src: field?.jsonValue?.value?.src ?? '', alt: field?.jsonValue?.value?.alt ?? '' });
const sl = (field: any) => ({ href: field?.jsonValue?.value?.href ?? '', text: field?.jsonValue?.value?.text ?? '', target: field?.jsonValue?.value?.target ?? '' });

const features = (datasource?.children?.results ?? []).map((f: any) => ({
  id: f.id || '',
  featureTagLine: sf(f.featureTagLine),
  featureHeading: sf(f.featureHeading),
  featureDescription: sf(f.featureDescription),
  featureIcon: si(f.featureIcon),
  featureImage: si(f.featureImage),
  featureLink1: sl(f.featureLink1),
  featureLink2: sl(f.featureLink2),
}));

const sectionData = {
  heading: sf(datasource?.heading),
  tagLine: sf(datasource?.tagLine),
  body: sf(datasource?.body),
  image: si(datasource?.image),
  link1: sl(datasource?.link1),
  link2: sl(datasource?.link2),
};
---

{datasource ? (
  <FeaturesSectionIsland
    client:visible
    variant={variant}
    styles={styles}
    renderingId={id}
    sectionData={sectionData}
    features={features}
    isEditing={isEditing}
  />
) : (
  <div class="is-empty-hint">Features Section</div>
)}
