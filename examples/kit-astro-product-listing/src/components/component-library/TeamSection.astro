---
import type { ComponentProps } from "@/lib/component-props";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const variant = params?.FieldNames || params?.Variant || 'Default';
const styles = params?.styles || '';

const datasource = fields?.data?.datasource;

const sf = (f: any) => f?.jsonValue?.value ?? '';
const si = (f: any) => ({ src: f?.jsonValue?.value?.src ?? '', alt: f?.jsonValue?.value?.alt ?? '' });
const sl = (f: any) => ({ href: f?.jsonValue?.value?.href ?? '', text: f?.jsonValue?.value?.text ?? '', target: f?.jsonValue?.value?.target ?? '' });

const members = (datasource?.children?.results ?? []).map((tm: any) => ({
  id: tm.id || '',
  image: si(tm.image),
  fullName: sf(tm.fullName),
  jobTitle: sf(tm.jobTitle),
  description: sf(tm.description),
  facebook: sl(tm.facebook),
  instagram: sl(tm.instagram),
  linkedIn: sl(tm.linkedIn),
  twitterX: sl(tm.twitterX),
}));

const d = {
  tagLine: sf(datasource?.tagLine),
  heading: sf(datasource?.heading),
  text: sf(datasource?.text),
  heading2: sf(datasource?.heading2),
  text2: sf(datasource?.text2),
  link: sl(datasource?.link),
};

const fbSvg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" fill="currentColor"><path d="M512 256C512 114.6 397.4 0 256 0S0 114.6 0 256c0 120 82.7 220.8 194.2 248.5V330.3h-58.5V256h58.5v-56.6c0-57.7 34.4-89.6 87-89.6 25.2 0 51.5 4.5 51.5 4.5v56.8H304c-28.5 0-37.4 17.7-37.4 35.8V256h64l-10.2 74.3h-53.8v174.2C429.3 476.8 512 376 512 256z"/></svg>';
const igSvg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" fill="currentColor"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/></svg>';
const liSvg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" fill="currentColor"><path d="M100.3 448H7.4V148.9h92.9zM53.8 108.1C24.1 108.1 0 83.5 0 53.8a53.8 53.8 0 01107.6 0c0 29.7-24.1 54.3-53.8 54.3zM447.9 448h-92.7V302.4c0-34.7-.7-79.2-48.3-79.2-48.3 0-55.7 37.7-55.7 76.7V448h-92.8V148.9h89.1v40.8h1.3c12.4-23.5 42.7-48.3 87.9-48.3 94 0 111.3 61.9 111.3 142.3V448z"/></svg>';
const twSvg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" fill="currentColor"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"/></svg>';

function hasValidLink(link: any): boolean {
  return !!(link.href && link.href !== '#' && !link.href.startsWith('http://#'));
}

type ImgType = 'circle' | 'square' | 'rectangle';
type MemType = 'simple' | 'horizontal';

const cfg: Record<string, any> = {
  Default:       { l: 'v', c: 3, ct: true, mt: 'simple', it: 'circle', mc: true },
  TeamSection1:  { l: 'v', c: 3, ct: true, mt: 'simple', it: 'rectangle', mc: true },
  TeamSection2:  { l: 'v', c: 4, ct: true, mt: 'simple', it: 'circle' },
  TeamSection3:  { l: 'v', c: 4, ct: true, mt: 'simple', it: 'square' },
  TeamSection4:  { l: 'v', c: 2, ct: true, mt: 'horizontal', it: 'circle' },
  TeamSection5:  { l: 'v', c: 2, ct: true, mt: 'horizontal', it: 'square' },
  TeamSection6:  { l: 'h', c: 2, mt: 'simple', it: 'circle' },
  TeamSection7:  { l: 'h', c: 2, mt: 'simple', it: 'rectangle' },
  TeamSection8:  { l: 'h', c: 1, mt: 'horizontal', it: 'circle' },
  TeamSection9:  { l: 'h', c: 1, mt: 'horizontal', it: 'square' },
  TeamSection10: { l: 'car', c: 1, mt: 'simple', it: 'circle' },
  TeamSection11: { l: 'car', c: 1, mt: 'simple', it: 'square' },
};

const c = cfg[variant] || cfg['Default'];
const layout = c.l as string;
const columns = c.c as number;
const centered = c.ct || false;
const memType = c.mt as MemType;
const imgType = c.it as ImgType;
const memCentered = c.mc || false;
const isCarousel = layout === 'car';
const isHorizontal = layout === 'h';

function imgClass(type: ImgType, extra = ''): string {
  if (type === 'circle') return `inline-block object-cover rounded-full ${extra}`;
  if (type === 'rectangle') return `inline-block w-full object-cover aspect-3/2 ${extra}`;
  return `inline-block w-full object-cover aspect-square ${extra}`;
}

function gridCols(n: number): string {
  if (n === 1) return '';
  if (n === 2) return 'md:grid-cols-2';
  if (n === 3) return 'md:grid-cols-2 lg:grid-cols-3';
  return 'md:grid-cols-2 lg:grid-cols-4';
}
---

{datasource ? (
  isHorizontal ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class={`grid md:grid-cols-${columns + 1} gap-x-16 gap-y-12`}>
          <div>
            {d.tagLine && <p class="font-semibold mb-4">{d.tagLine}</p>}
            <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
            {d.text && <div class="text-lg" set:html={d.text} />}
            {d.link.href && <a href={d.link.href} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground mt-8">{d.link.text}</a>}
          </div>
          <div class={`grid ${gridCols(columns)} gap-8 md:col-span-${columns}`}>
            {members.map((tm) => (
              memType === 'horizontal' ? (
                <div class="flex items-start gap-12">
                  {tm.image.src && <img src={tm.image.src} alt={tm.image.alt} class={imgClass(imgType, 'shrink-0 max-w-1/3')} loading="lazy" />}
                  <div>
                    <h3 class="text-lg font-bold">{tm.fullName}</h3>
                    <p class="text-lg mb-4">{tm.jobTitle}</p>
                    {tm.description && <div set:html={tm.description} />}
                    <div class="flex gap-4 mt-6">
                      {hasValidLink(tm.facebook) ? <a href={tm.facebook.href} aria-label="Facebook"><span class="w-5 h-5 inline-block" set:html={fbSvg} /></a> : <span role="img" aria-label="Facebook"><span class="w-5 h-5 inline-block" set:html={fbSvg} /></span>}
                      {hasValidLink(tm.instagram) ? <a href={tm.instagram.href} aria-label="Instagram"><span class="w-5 h-5 inline-block" set:html={igSvg} /></a> : <span role="img" aria-label="Instagram"><span class="w-5 h-5 inline-block" set:html={igSvg} /></span>}
                      {hasValidLink(tm.linkedIn) ? <a href={tm.linkedIn.href} aria-label="LinkedIn"><span class="w-5 h-5 inline-block" set:html={liSvg} /></a> : <span role="img" aria-label="LinkedIn"><span class="w-5 h-5 inline-block" set:html={liSvg} /></span>}
                      {hasValidLink(tm.twitterX) ? <a href={tm.twitterX.href} aria-label="X (Twitter)"><span class="w-5 h-5 inline-block" set:html={twSvg} /></a> : <span role="img" aria-label="X (Twitter)"><span class="w-5 h-5 inline-block" set:html={twSvg} /></span>}
                    </div>
                  </div>
                </div>
              ) : (
                <div>
                  {tm.image.src && <img src={tm.image.src} alt={tm.image.alt} class={imgClass(imgType)} loading="lazy" />}
                  <h3 class="text-lg font-bold mt-6">{tm.fullName}</h3>
                  <p class="text-lg mb-4">{tm.jobTitle}</p>
                  {tm.description && <div set:html={tm.description} />}
                  <div class="flex gap-4 mt-6">
                    {hasValidLink(tm.facebook) ? <a href={tm.facebook.href} aria-label="Facebook"><span class="w-5 h-5 inline-block" set:html={fbSvg} /></a> : <span role="img" aria-label="Facebook"><span class="w-5 h-5 inline-block" set:html={fbSvg} /></span>}
                    {hasValidLink(tm.instagram) ? <a href={tm.instagram.href} aria-label="Instagram"><span class="w-5 h-5 inline-block" set:html={igSvg} /></a> : <span role="img" aria-label="Instagram"><span class="w-5 h-5 inline-block" set:html={igSvg} /></span>}
                    {hasValidLink(tm.linkedIn) ? <a href={tm.linkedIn.href} aria-label="LinkedIn"><span class="w-5 h-5 inline-block" set:html={liSvg} /></a> : <span role="img" aria-label="LinkedIn"><span class="w-5 h-5 inline-block" set:html={liSvg} /></span>}
                    {hasValidLink(tm.twitterX) ? <a href={tm.twitterX.href} aria-label="X (Twitter)"><span class="w-5 h-5 inline-block" set:html={twSvg} /></a> : <span role="img" aria-label="X (Twitter)"><span class="w-5 h-5 inline-block" set:html={twSvg} /></span>}
                  </div>
                </div>
              )
            ))}
          </div>
        </div>
      </div>
    </section>
  ) : isCarousel ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class="max-w-3xl mx-auto text-center">
          {d.tagLine && <p class="font-semibold mb-4">{d.tagLine}</p>}
          <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
          {d.text && <div class="text-lg" set:html={d.text} />}
        </div>
        <div class="my-20">
          <astro-team-carousel class="block relative">
            <div class="overflow-hidden" data-carousel-viewport>
              <div class="flex transition-transform duration-300 ease-in-out pb-16" data-carousel-track>
                {members.map((tm) => (
                  <div class="flex-shrink-0 w-full md:w-1/2 lg:w-1/3 px-4" data-carousel-item>
                    <div class={memType === 'horizontal' ? '' : 'text-center'}>
                      {tm.image.src && <img src={tm.image.src} alt={tm.image.alt} class={imgClass(imgType)} loading="lazy" />}
                      <h3 class="text-lg font-bold mt-6">{tm.fullName}</h3>
                      <p class="text-lg mb-4">{tm.jobTitle}</p>
                      {tm.description && <div set:html={tm.description} />}
                      <div class={`flex ${memType === 'horizontal' ? '' : 'justify-center'} gap-4 mt-6`}>
                        {hasValidLink(tm.facebook) ? <a href={tm.facebook.href} aria-label="Facebook"><span class="w-5 h-5 inline-block" set:html={fbSvg} /></a> : <span role="img" aria-label="Facebook"><span class="w-5 h-5 inline-block" set:html={fbSvg} /></span>}
                        {hasValidLink(tm.instagram) ? <a href={tm.instagram.href} aria-label="Instagram"><span class="w-5 h-5 inline-block" set:html={igSvg} /></a> : <span role="img" aria-label="Instagram"><span class="w-5 h-5 inline-block" set:html={igSvg} /></span>}
                        {hasValidLink(tm.linkedIn) ? <a href={tm.linkedIn.href} aria-label="LinkedIn"><span class="w-5 h-5 inline-block" set:html={liSvg} /></a> : <span role="img" aria-label="LinkedIn"><span class="w-5 h-5 inline-block" set:html={liSvg} /></span>}
                        {hasValidLink(tm.twitterX) ? <a href={tm.twitterX.href} aria-label="X (Twitter)"><span class="w-5 h-5 inline-block" set:html={twSvg} /></a> : <span role="img" aria-label="X (Twitter)"><span class="w-5 h-5 inline-block" set:html={twSvg} /></span>}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <div class="absolute bottom-0 right-0 flex items-center gap-2">
              <button data-carousel-prev class="inline-flex items-center justify-center rounded-full border p-2 hover:bg-accent disabled:opacity-50" aria-label="Previous">
                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
              </button>
              <button data-carousel-next class="inline-flex items-center justify-center rounded-full border p-2 hover:bg-accent disabled:opacity-50" aria-label="Next">
                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </button>
            </div>
          </astro-team-carousel>
        </div>
        <div class="max-w-3xl mx-auto text-center">
          <h3 class="text-3xl font-bold mb-4">{d.heading2}</h3>
          {d.text2 && <div class="text-lg" set:html={d.text2} />}
          {d.link.href && <a href={d.link.href} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground mt-8">{d.link.text}</a>}
        </div>
      </div>
    </section>
  ) : (
    /* Vertical layout (Default, TeamSection1-5) */
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class={centered ? 'max-w-3xl mx-auto text-center' : ''}>
          {d.tagLine && <p class="font-semibold mb-4">{d.tagLine}</p>}
          <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
          {d.text && <div class="text-lg" set:html={d.text} />}
        </div>
        <div class={`grid ${gridCols(columns)} ${columns === 2 ? 'gap-16' : 'gap-x-8 gap-y-16'} my-20`}>
          {members.map((tm) => (
            memType === 'horizontal' ? (
              <div class="flex items-start gap-12">
                {tm.image.src && <img src={tm.image.src} alt={tm.image.alt} class={imgClass(imgType, 'shrink-0 max-w-1/3')} loading="lazy" />}
                <div>
                  <h3 class="text-lg font-bold">{tm.fullName}</h3>
                  <p class="text-lg mb-4">{tm.jobTitle}</p>
                  {tm.description && <div set:html={tm.description} />}
                  <div class="flex gap-4 mt-6">
                    {hasValidLink(tm.facebook) ? <a href={tm.facebook.href} aria-label="Facebook"><span class="w-5 h-5 inline-block" set:html={fbSvg} /></a> : <span role="img" aria-label="Facebook"><span class="w-5 h-5 inline-block" set:html={fbSvg} /></span>}
                    {hasValidLink(tm.instagram) ? <a href={tm.instagram.href} aria-label="Instagram"><span class="w-5 h-5 inline-block" set:html={igSvg} /></a> : <span role="img" aria-label="Instagram"><span class="w-5 h-5 inline-block" set:html={igSvg} /></span>}
                    {hasValidLink(tm.linkedIn) ? <a href={tm.linkedIn.href} aria-label="LinkedIn"><span class="w-5 h-5 inline-block" set:html={liSvg} /></a> : <span role="img" aria-label="LinkedIn"><span class="w-5 h-5 inline-block" set:html={liSvg} /></span>}
                    {hasValidLink(tm.twitterX) ? <a href={tm.twitterX.href} aria-label="X (Twitter)"><span class="w-5 h-5 inline-block" set:html={twSvg} /></a> : <span role="img" aria-label="X (Twitter)"><span class="w-5 h-5 inline-block" set:html={twSvg} /></span>}
                  </div>
                </div>
              </div>
            ) : (
              <div class={memCentered ? 'text-center' : ''}>
                {tm.image.src && <img src={tm.image.src} alt={tm.image.alt} class={imgClass(imgType)} loading="lazy" />}
                <h3 class="text-lg font-bold mt-6">{tm.fullName}</h3>
                <p class="text-lg mb-4">{tm.jobTitle}</p>
                {tm.description && <div set:html={tm.description} />}
                <div class={`flex ${memCentered ? 'justify-center' : ''} gap-4 mt-6`}>
                  {hasValidLink(tm.facebook) ? <a href={tm.facebook.href} aria-label="Facebook"><span class="w-5 h-5 inline-block" set:html={fbSvg} /></a> : <span role="img" aria-label="Facebook"><span class="w-5 h-5 inline-block" set:html={fbSvg} /></span>}
                  {hasValidLink(tm.instagram) ? <a href={tm.instagram.href} aria-label="Instagram"><span class="w-5 h-5 inline-block" set:html={igSvg} /></a> : <span role="img" aria-label="Instagram"><span class="w-5 h-5 inline-block" set:html={igSvg} /></span>}
                  {hasValidLink(tm.linkedIn) ? <a href={tm.linkedIn.href} aria-label="LinkedIn"><span class="w-5 h-5 inline-block" set:html={liSvg} /></a> : <span role="img" aria-label="LinkedIn"><span class="w-5 h-5 inline-block" set:html={liSvg} /></span>}
                  {hasValidLink(tm.twitterX) ? <a href={tm.twitterX.href} aria-label="X (Twitter)"><span class="w-5 h-5 inline-block" set:html={twSvg} /></a> : <span role="img" aria-label="X (Twitter)"><span class="w-5 h-5 inline-block" set:html={twSvg} /></span>}
                </div>
              </div>
            )
          ))}
        </div>
        <div class={centered ? 'max-w-3xl mx-auto text-center' : ''}>
          <h3 class="text-3xl font-bold mb-4">{d.heading2}</h3>
          {d.text2 && <div class="text-lg" set:html={d.text2} />}
          {d.link.href && <a href={d.link.href} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground mt-8">{d.link.text}</a>}
        </div>
      </div>
    </section>
  )
) : (
  <div class="is-empty-hint">Team Section</div>
)}

<script>
  class AstroTeamCarousel extends HTMLElement {
    private track: HTMLElement | null = null;
    private viewport: HTMLElement | null = null;
    private prevBtn: HTMLButtonElement | null = null;
    private nextBtn: HTMLButtonElement | null = null;
    private currentSlide = 0;
    private itemCount = 0;

    connectedCallback() {
      this.track = this.querySelector('[data-carousel-track]');
      this.viewport = this.querySelector('[data-carousel-viewport]');
      this.prevBtn = this.querySelector('[data-carousel-prev]');
      this.nextBtn = this.querySelector('[data-carousel-next]');

      if (!this.track || !this.viewport) return;

      this.itemCount = this.track.querySelectorAll('[data-carousel-item]').length;
      this.updateButtons();

      this.prevBtn?.addEventListener('click', () => this.go(this.currentSlide - 1));
      this.nextBtn?.addEventListener('click', () => this.go(this.currentSlide + 1));

      let startX = 0;
      let prevTranslate = 0;
      let dragging = false;

      this.viewport.addEventListener('touchstart', (e: TouchEvent) => {
        dragging = true;
        startX = e.touches[0].clientX;
        if (this.track) this.track.style.transition = 'none';
      }, { passive: true });

      this.viewport.addEventListener('touchmove', (e: TouchEvent) => {
        if (!dragging || !this.track) return;
        const diff = e.touches[0].clientX - startX;
        this.track.style.transform = `translateX(${prevTranslate + diff}px)`;
      }, { passive: true });

      this.viewport.addEventListener('touchend', () => {
        if (!dragging || !this.track) return;
        dragging = false;
        this.track.style.transition = 'transform 300ms ease-in-out';
        const current = new DOMMatrix(getComputedStyle(this.track).transform).m41;
        const diff = current - prevTranslate;
        const threshold = this.getSlideWidth() / 4;
        if (diff < -threshold) this.go(this.currentSlide + 1);
        else if (diff > threshold) this.go(this.currentSlide - 1);
        else this.go(this.currentSlide);
        prevTranslate = -this.currentSlide * this.getSlideWidth();
      });

      window.addEventListener('resize', () => this.go(this.currentSlide));
    }

    getSlideWidth(): number {
      if (!this.track) return 0;
      const item = this.track.querySelector('[data-carousel-item]') as HTMLElement;
      return item ? item.getBoundingClientRect().width : 0;
    }

    go(index: number) {
      this.currentSlide = Math.max(0, Math.min(index, this.itemCount - 1));
      const offset = -this.currentSlide * this.getSlideWidth();
      if (this.track) {
        this.track.style.transform = `translateX(${offset}px)`;
      }
      this.updateButtons();
    }

    updateButtons() {
      if (this.prevBtn) this.prevBtn.disabled = this.currentSlide <= 0;
      if (this.nextBtn) this.nextBtn.disabled = this.currentSlide >= this.itemCount - 1;
    }
  }

  customElements.define('astro-team-carousel', AstroTeamCarousel);
</script>
