---
import type { ComponentProps } from "@/lib/component-props";
import { generateFAQPageSchema } from "@/lib/structured-data/schema";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;

const variant = params?.FieldNames || params?.Variant || 'Default';
const styles = params?.styles || '';

const datasource = fields?.data?.datasource;

const sf = (field: any) => field?.jsonValue?.value ?? '';
const si = (field: any) => ({ src: field?.jsonValue?.value?.src ?? '', alt: field?.jsonValue?.value?.alt ?? '' });
const sl = (field: any) => ({ href: field?.jsonValue?.value?.href ?? '', text: field?.jsonValue?.value?.text ?? '', target: field?.jsonValue?.value?.target ?? '' });

const questions = (datasource?.children?.results ?? []).map((q: any) => ({
  id: q.id || '',
  question: sf(q.question),
  answer: sf(q.answer),
  image: si(q.image),
}));

const d = {
  heading: sf(datasource?.heading),
  text: sf(datasource?.text),
  heading2: sf(datasource?.heading2),
  text2: sf(datasource?.text2),
  link: sl(datasource?.link),
};

const faqSchema = generateFAQPageSchema(questions.map((q) => ({ question: q.question, answer: q.answer })));
const faqSchemaJson = faqSchema ? JSON.stringify(faqSchema) : '';

const useAccordion = ['Default', 'FAQ1', 'FAQ2', 'FAQ3'].includes(variant);
const evenQuestions = questions.filter((_: any, i: number) => i % 2 === 0);
const oddQuestions = questions.filter((_: any, i: number) => i % 2 !== 0);
---

{datasource ? (
  variant === 'FAQ1' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      {faqSchemaJson && <script type="application/ld+json" set:html={faqSchemaJson} />}
      <div class="container mx-auto">
        <h2 class="text-3xl font-semibold mb-6">{d.heading}</h2>
        <div class="flex gap-4 mb-6 text-base font-semibold" data-faq-controls>
          <button data-faq-expand class="px-2 text-primary underline cursor-pointer">Expand All</button>|
          <button data-faq-collapse class="px-2 opacity-40 cursor-not-allowed" disabled>Collapse All</button>
        </div>
        <div class="w-full" data-faq-accordion>
          {questions.map((q) => (
            <details class="border-gray-300 first:border-t border-b group" data-faq-item>
              <summary class="flex flex-row-reverse justify-end py-6 px-2 text-base cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <span>{q.question}</span>
                <svg class="shrink-0 w-4 h-4 me-6 mt-1 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <div class="text-base pb-6 ps-10" set:html={q.answer} />
            </details>
          ))}
        </div>
      </div>
    </section>
  ) : variant === 'FAQ2' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      {faqSchemaJson && <script type="application/ld+json" set:html={faqSchemaJson} />}
      <div class="container mx-auto">
        <div class="grid gap-x-20 gap-y-12 md:grid-cols-2">
          <div>
            <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
            {d.text && <div class="text-lg" set:html={d.text} />}
            {d.link.href && <a href={d.link.href} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground mt-8">{d.link.text}</a>}
          </div>
          <div class="grid gap-4">
            {questions.map((q) => (
              <details class="border last:border group">
                <summary class="flex justify-between items-center px-8 py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                  <span>{q.question}</span>
                  <svg class="shrink-0 w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </summary>
                <div class="px-8 pb-4" set:html={q.answer} />
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>
  ) : variant === 'FAQ3' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      {faqSchemaJson && <script type="application/ld+json" set:html={faqSchemaJson} />}
      <div class="container mx-auto">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
          {d.text && <div class="text-lg" set:html={d.text} />}
        </div>
        <div class="grid md:grid-cols-2 gap-4 items-start my-20">
          <div class="grid gap-4">
            {evenQuestions.map((q) => (
              <details class="border last:border group">
                <summary class="flex justify-between items-center px-8 py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                  <span>{q.question}</span>
                  <svg class="shrink-0 w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </summary>
                <div class="px-8 pb-4" set:html={q.answer} />
              </details>
            ))}
          </div>
          <div class="grid gap-4">
            {oddQuestions.map((q) => (
              <details class="border last:border group">
                <summary class="flex justify-between items-center px-8 py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                  <span>{q.question}</span>
                  <svg class="shrink-0 w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </summary>
                <div class="px-8 pb-4" set:html={q.answer} />
              </details>
            ))}
          </div>
        </div>
        <div class="max-w-3xl mx-auto text-center">
          <h3 class="text-3xl font-bold mb-4">{d.heading2}</h3>
          {d.text2 && <div class="text-lg" set:html={d.text2} />}
          {d.link.href && <a href={d.link.href} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground mt-8">{d.link.text}</a>}
        </div>
      </div>
    </section>
  ) : variant === 'FAQ4' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      {faqSchemaJson && <script type="application/ld+json" set:html={faqSchemaJson} />}
      <div class="container mx-auto">
        <div class="max-w-3xl mx-auto">
          <div class="text-center">
            <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
            {d.text && <div class="text-lg" set:html={d.text} />}
          </div>
          <div class="grid gap-12 my-20">
            {questions.map((q) => (
              <div>
                <h3 class="text-lg font-bold mb-4">{q.question}</h3>
                <div set:html={q.answer} />
              </div>
            ))}
          </div>
          <div class="text-center">
            <h3 class="text-3xl font-bold mb-4">{d.heading2}</h3>
            {d.text2 && <div class="text-lg" set:html={d.text2} />}
            {d.link.href && <a href={d.link.href} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground mt-8">{d.link.text}</a>}
          </div>
        </div>
      </div>
    </section>
  ) : variant === 'FAQ5' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      {faqSchemaJson && <script type="application/ld+json" set:html={faqSchemaJson} />}
      <div class="container mx-auto">
        <div class="grid gap-x-20 gap-y-12 md:grid-cols-2">
          <div>
            <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
            {d.text && <div class="text-lg" set:html={d.text} />}
            {d.link.href && <a href={d.link.href} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground mt-8">{d.link.text}</a>}
          </div>
          <div class="grid gap-12">
            {questions.map((q) => (
              <div>
                <h3 class="text-lg font-bold mb-4">{q.question}</h3>
                <div set:html={q.answer} />
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  ) : variant === 'FAQ6' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      {faqSchemaJson && <script type="application/ld+json" set:html={faqSchemaJson} />}
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
          {d.text && <div class="text-lg" set:html={d.text} />}
        </div>
        <div class="my-20">
          {questions.map((q) => (
            <div class="grid md:grid-cols-2 gap-4 border-t pt-6 pb-12">
              <h3 class="text-lg font-bold mb-4">{q.question}</h3>
              <div set:html={q.answer} />
            </div>
          ))}
        </div>
        <div class="max-w-3xl">
          <h3 class="text-3xl font-bold mb-4">{d.heading2}</h3>
          {d.text2 && <div class="text-lg" set:html={d.text2} />}
          {d.link.href && <a href={d.link.href} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground mt-8">{d.link.text}</a>}
        </div>
      </div>
    </section>
  ) : variant === 'FAQ7' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      {faqSchemaJson && <script type="application/ld+json" set:html={faqSchemaJson} />}
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
          {d.text && <div class="text-lg" set:html={d.text} />}
        </div>
        <div class="grid md:grid-cols-2 gap-16 my-20">
          {questions.map((q) => (
            <div>
              {q.image.src && <img src={q.image.src} alt={q.image.alt} class="object-contain mb-6 w-[50px] h-[50px]" loading="lazy" />}
              <h3 class="text-lg font-bold mb-4">{q.question}</h3>
              <div set:html={q.answer} />
            </div>
          ))}
        </div>
        <div class="max-w-3xl">
          <h3 class="text-3xl font-bold mb-4">{d.heading2}</h3>
          {d.text2 && <div class="text-lg" set:html={d.text2} />}
          {d.link.href && <a href={d.link.href} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground mt-8">{d.link.text}</a>}
        </div>
      </div>
    </section>
  ) : variant === 'FAQ8' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      {faqSchemaJson && <script type="application/ld+json" set:html={faqSchemaJson} />}
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
          {d.text && <div class="text-lg" set:html={d.text} />}
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-16 my-20">
          {questions.map((q) => (
            <div class="text-center">
              {q.image.src && <img src={q.image.src} alt={q.image.alt} class="object-contain mx-auto mb-6 w-[50px] h-[50px]" loading="lazy" />}
              <h3 class="text-lg font-bold mb-4">{q.question}</h3>
              <div set:html={q.answer} />
            </div>
          ))}
        </div>
        <div class="max-w-3xl">
          <h3 class="text-3xl font-bold mb-4">{d.heading2}</h3>
          {d.text2 && <div class="text-lg" set:html={d.text2} />}
          {d.link.href && <a href={d.link.href} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground mt-8">{d.link.text}</a>}
        </div>
      </div>
    </section>
  ) : (
    /* Default */
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      {faqSchemaJson && <script type="application/ld+json" set:html={faqSchemaJson} />}
      <div class="container mx-auto">
        <div class="max-w-3xl mx-auto">
          <div class="text-center">
            <h2 class="text-5xl font-bold mb-6">{d.heading}</h2>
            {d.text && <div class="text-lg" set:html={d.text} />}
          </div>
          <div class="my-20">
            {questions.map((q) => (
              <details class="border-gray-300 first:border-t border-b group">
                <summary class="flex justify-between items-center py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                  <span>{q.question}</span>
                  <svg class="shrink-0 w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </summary>
                <div class="pb-4" set:html={q.answer} />
              </details>
            ))}
          </div>
          <div class="text-center">
            <h3 class="text-3xl font-bold mb-4">{d.heading2}</h3>
            {d.text2 && <div class="text-lg" set:html={d.text2} />}
            {d.link.href && <a href={d.link.href} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground mt-8">{d.link.text}</a>}
          </div>
        </div>
      </div>
    </section>
  )
) : (
  <div class="is-empty-hint">FAQ</div>
)}

<script>
  // FAQ1 expand/collapse all
  document.querySelectorAll('[data-faq-controls]').forEach((controls) => {
    const container = controls.closest('section');
    if (!container) return;
    const expandBtn = controls.querySelector('[data-faq-expand]') as HTMLButtonElement;
    const collapseBtn = controls.querySelector('[data-faq-collapse]') as HTMLButtonElement;
    const items = container.querySelectorAll('[data-faq-item]') as NodeListOf<HTMLDetailsElement>;

    function updateButtons() {
      const openCount = container!.querySelectorAll('[data-faq-item][open]').length;
      expandBtn.disabled = openCount === items.length;
      expandBtn.classList.toggle('opacity-40', openCount === items.length);
      expandBtn.classList.toggle('cursor-not-allowed', openCount === items.length);
      expandBtn.classList.toggle('cursor-pointer', openCount !== items.length);
      collapseBtn.disabled = openCount === 0;
      collapseBtn.classList.toggle('opacity-40', openCount === 0);
      collapseBtn.classList.toggle('cursor-not-allowed', openCount === 0);
      collapseBtn.classList.toggle('cursor-pointer', openCount !== 0);
    }

    expandBtn?.addEventListener('click', () => {
      items.forEach((item) => item.open = true);
      updateButtons();
    });

    collapseBtn?.addEventListener('click', () => {
      items.forEach((item) => item.open = false);
      updateButtons();
    });

    items.forEach((item) => item.addEventListener('toggle', updateButtons));
  });
</script>
