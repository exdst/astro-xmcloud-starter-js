---
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const variant = params?.FieldNames || params?.Variant || 'Default';
const styles = params?.styles || '';

const datasource = fields?.data?.datasource;

const sf = (f: any) => f?.jsonValue?.value ?? '';
const si = (f: any) => ({ src: f?.jsonValue?.value?.src ?? '', alt: f?.jsonValue?.value?.alt ?? '' });
const sl = (f: any) => ({ href: f?.jsonValue?.value?.href ?? '', text: f?.jsonValue?.value?.text ?? '', target: f?.jsonValue?.value?.target ?? '' });

const testimonials = (datasource?.children?.results ?? []).map((t: any) => ({
  id: t.id || '',
  caseStudyLink: sl(t.caseStudyLink),
  customerName: sf(t.customerName),
  customerCompany: sf(t.customerCompany),
  customerIcon: si(t.customerIcon),
  testimonialBody: sf(t.testimonialBody),
  testimonialIcon: si(t.testimonialIcon),
  testimonialRating: sf(t.testimonialRating),
}));

const d = {
  title: sf(datasource?.title),
  tagLine: sf(datasource?.tagLine),
};

function starHtml(rating: string): string {
  const n = Math.min(Number(rating) || 0, 5);
  let html = '<div class="flex gap-1 mb-6">';
  for (let i = 0; i < n; i++) html += '<span class="text-yellow-500">&#9733;</span>';
  for (let i = 0; i < 5 - n; i++) html += '<span class="text-gray-300">&#9734;</span>';
  html += '</div>';
  return html;
}

const hasCarousel = ['Testimonials1','Testimonials2','Testimonials3','Testimonials4','Testimonials5','Testimonials8'].includes(variant);
const hasTabs = variant === 'Testimonials9';
---

{datasource ? (
  variant === 'Default' ? (
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class="max-w-3xl mb-20 mx-auto text-center">
          <h2 class="text-5xl font-bold mb-6">{d.title}</h2>
          <p class="text-lg">{d.tagLine}</p>
        </div>
        <div class="flex flex-col md:flex-row gap-x-12 gap-y-20">
          {testimonials.map((t) => (
            <div class="flex flex-col items-center max-w-3xl mx-auto flex-1">
              {t.testimonialIcon.src && <div class="h-12 mb-12"><img src={t.testimonialIcon.src} alt={t.testimonialIcon.alt} class="h-full w-auto object-contain" loading="lazy" /></div>}
              <blockquote class="text-xl font-bold mb-12 text-center" set:html={t.testimonialBody} />
              <div class="flex gap-4 mt-auto flex-col items-center text-center">
                {t.customerIcon.src && <div class="shrink-0 w-12 h-12 rounded-full overflow-hidden"><img src={t.customerIcon.src} alt={t.customerIcon.alt} class="w-full h-full object-cover" loading="lazy" /></div>}
                <div><div class="font-semibold">{t.customerName}</div><div>{t.customerCompany}</div></div>
              </div>
              {t.caseStudyLink.href && <a href={t.caseStudyLink.href} class="inline-flex items-center text-sm font-medium underline-offset-4 hover:underline mt-6">{t.caseStudyLink.text} &rarr;</a>}
            </div>
          ))}
        </div>
      </div>
    </section>
  ) : variant === 'Testimonials1' ? (
