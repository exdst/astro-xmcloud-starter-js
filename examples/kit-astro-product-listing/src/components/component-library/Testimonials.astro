        </div>
      </div>
    </section>
  ) : (
    /* Fallback */
    <section class={`py-24 px-4 ${styles}`} data-class-change>
      <div class="container mx-auto">
        <div class="max-w-3xl mb-20 mx-auto text-center">
          <h2 class="text-5xl font-bold mb-6">{d.title}</h2>
          <p class="text-lg">{d.tagLine}</p>
        </div>
        <div class="flex flex-col md:flex-row gap-x-12 gap-y-20">
          {testimonials.map((t) => (
            <div class="flex flex-col items-center max-w-3xl mx-auto flex-1">
              {t.testimonialIcon.src && <div class="h-12 mb-12"><img src={t.testimonialIcon.src} alt={t.testimonialIcon.alt} class="h-full w-auto object-contain" loading="lazy" /></div>}
              <blockquote class="text-xl font-bold mb-12 text-center" set:html={t.testimonialBody} />
              <div class="flex gap-4 mt-auto flex-col items-center text-center">
                {t.customerIcon.src && <div class="shrink-0 w-12 h-12 rounded-full overflow-hidden"><img src={t.customerIcon.src} alt={t.customerIcon.alt} class="w-full h-full object-cover" loading="lazy" /></div>}
                <div><div class="font-semibold">{t.customerName}</div><div>{t.customerCompany}</div></div>
              </div>
              {t.caseStudyLink.href && <a href={t.caseStudyLink.href} class="inline-flex items-center text-sm font-medium underline-offset-4 hover:underline mt-6">{t.caseStudyLink.text} &rarr;</a>}
            </div>
          ))}
        </div>
      </div>
    </section>
  )
) : (
  <div class="is-empty-hint">Testimonials</div>
)}

<script>
  class AstroTestimonialCarousel extends HTMLElement {
    private track: HTMLElement | null = null;
    private viewport: HTMLElement | null = null;
    private prevBtn: HTMLButtonElement | null = null;
    private nextBtn: HTMLButtonElement | null = null;
    private currentSlide = 0;
    private itemCount = 0;

    connectedCallback() {
      this.track = this.querySelector('[data-carousel-track]');
      this.viewport = this.querySelector('[data-carousel-viewport]');
      this.prevBtn = this.querySelector('[data-carousel-prev]');
      this.nextBtn = this.querySelector('[data-carousel-next]');

      if (!this.track || !this.viewport) return;

      this.itemCount = this.track.querySelectorAll('[data-carousel-item]').length;
      this.updateButtons();

      this.prevBtn?.addEventListener('click', () => this.go(this.currentSlide - 1));
      this.nextBtn?.addEventListener('click', () => this.go(this.currentSlide + 1));

      let startX = 0;
      let prevTranslate = 0;
      let dragging = false;

      this.viewport.addEventListener('touchstart', (e: TouchEvent) => {
        dragging = true;
        startX = e.touches[0].clientX;
        if (this.track) this.track.style.transition = 'none';
      }, { passive: true });

      this.viewport.addEventListener('touchmove', (e: TouchEvent) => {
        if (!dragging || !this.track) return;
        const diff = e.touches[0].clientX - startX;
        this.track.style.transform = `translateX(${prevTranslate + diff}px)`;
      }, { passive: true });

      this.viewport.addEventListener('touchend', () => {
        if (!dragging || !this.track) return;
        dragging = false;
        this.track.style.transition = 'transform 300ms ease-in-out';
        const current = new DOMMatrix(getComputedStyle(this.track).transform).m41;
        const diff = current - prevTranslate;
        const threshold = this.getSlideWidth() / 4;
        if (diff < -threshold) this.go(this.currentSlide + 1);
        else if (diff > threshold) this.go(this.currentSlide - 1);
        else this.go(this.currentSlide);
        prevTranslate = -this.currentSlide * this.getSlideWidth();
      });

      window.addEventListener('resize', () => this.go(this.currentSlide));
    }

    getSlideWidth(): number {
      if (!this.track) return 0;
      const item = this.track.querySelector('[data-carousel-item]') as HTMLElement;
      return item ? item.getBoundingClientRect().width : 0;
    }

    go(index: number) {
      this.currentSlide = Math.max(0, Math.min(index, this.itemCount - 1));
      const offset = -this.currentSlide * this.getSlideWidth();
      if (this.track) {
        this.track.style.transform = `translateX(${offset}px)`;
      }
      this.updateButtons();
    }

    updateButtons() {
      if (this.prevBtn) this.prevBtn.disabled = this.currentSlide <= 0;
      if (this.nextBtn) this.nextBtn.disabled = this.currentSlide >= this.itemCount - 1;
    }
  }

  customElements.define('astro-testimonial-carousel', AstroTestimonialCarousel);

  // Tabs for Testimonials9
  document.querySelectorAll('[data-testimonial-tabs]').forEach((container) => {
    const triggers = container.querySelectorAll('[data-tab-trigger]');
    const panels = container.querySelectorAll('[data-tab-panel]');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const id = trigger.getAttribute('data-tab-trigger');

        triggers.forEach((t) => {
          const isActive = t === trigger;
          t.setAttribute('aria-selected', isActive ? 'true' : 'false');
          t.classList.toggle('opacity-50', !isActive);
        });

        panels.forEach((p) => {
          p.classList.toggle('hidden', p.getAttribute('data-tab-panel') !== id);
        });
      });
    });
  });
</script>
