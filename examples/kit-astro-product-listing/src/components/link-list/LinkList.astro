---
import Link from "@exdst-sitecore-content-sdk/astro/components/Link.astro";
import Text from "@/components/shared/AppText.astro";
import type { ComponentProps } from "@/lib/component-props";

interface LinkListProps extends ComponentProps {
  fields: {
    data: {
      datasource: {
        children: {
          results: Array<{
            field: {
              link: any;
            };
          }>;
        };
        field: {
          title: { value?: string };
        };
      };
    };
  };
}

const { params, fields } = Astro.props as LinkListProps;
const datasource = fields?.data?.datasource;
const styleClasses = `component link-list ${params.styles || ""}`.trim();
const id = params.RenderingIdentifier;

const links = datasource?.children?.results?.filter((el) => el?.field?.link) ?? [];
const total = links.length;
const isFooterLinks = (params.styles || "").includes("with-separators") || (params.styles || "").includes("position-center");
const footerStyleClasses = `font-[inherit] ${params.styles || ""}`.trim();
---

{isFooterLinks ? (
  <div class={footerStyleClasses} id={id} data-class-change>
    {!datasource ? (
      <h3>Link List</h3>
    ) : (
      <div class="flex flex-col lg:flex-row lg:[.list-vertical_&]:flex-col flex-wrap [.position-center_&]:items-center [.position-center_&]:justify-center [.position-right_&]:items-end [.position-right_&]:justify-end gap-x-10 gap-y-6 font-[inherit]">
        {links.map((element) => {
          const href = element.field.link?.value?.href;
          const text = element.field.link?.value?.text;
          return (
            <>
              {href ? (
                <a href={href} class="font-[inherit]">
                  {text}
                </a>
              ) : (
                <Link field={element.field.link} class="font-[inherit]" />
              )}
              <span class="font-[inherit] last:!hidden hidden lg:[.with-separators_&]:inline-block">/</span>
            </>
          );
        })}
      </div>
    )}
  </div>
) : (
  <div class={styleClasses} id={id} data-class-change>
    <div class="flex flex-col lg:flex-row lg:[.list-vertical_&]:flex-col flex-wrap [.position-center_&]:items-center [.position-center_&]:justify-center [.position-right_&]:items-end [.position-right_&]:justify-end">
      {!datasource ? (
        <h3>Link List</h3>
      ) : (
        <>
          <Text tag="h3" field={datasource.field?.title} class="text-nowrap mb-5 text-xl font-bold text-gray-600" />
          <ul class="flex flex-col lg:flex-row lg:[.list-vertical_&]:flex-col flex-wrap list-none gap-1 p-0 m-0 [.position-center_&]:items-center [.position-center_&]:justify-center" aria-label="Navigation options">
            {links.map((element, index) => {
              const classNames = [
                `item${index}`,
                index % 2 === 0 ? "odd" : "even",
                index === 0 ? "first" : "",
                index === total - 1 ? "last" : "",
              ]
                .filter(Boolean)
                .join(" ");

              const href = element.field.link?.value?.href;
              const text = element.field.link?.value?.text;

              return (
                <li class={classNames}>
                  <div>
                    {href ? (
                      <a href={href} class="text-gray-600 hover:underline inline-block px-2 py-2 text-nowrap text-sm">
                        {text}
                      </a>
                    ) : (
                      <Link field={element.field.link} class="text-gray-600 hover:underline inline-block px-2 py-2 text-nowrap text-sm" />
                    )}
                  </div>
                </li>
              );
            })}
          </ul>
        </>
      )}
    </div>
  </div>
)}
