---
import Text from "@/components/shared/AppText.astro";
import Link from "@exdst-sitecore-content-sdk/astro/components/Link.astro";
import ZipcodeSearchForm from "@/components/forms/zipcode/ZipcodeSearchForm.astro";
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const title = fields?.title;
const description = fields?.description;
const bannerText = fields?.bannerText;
const bannerCTA = fields?.bannerCTA;
const image = fields?.image;
const dictionary = fields?.dictionary as Record<string, string> | undefined;
const searchLink = fields?.searchLink;

const hasPagesPositionStyles = params?.styles
  ? (params.styles as string).includes('position-')
  : false;

const positionClass = !hasPagesPositionStyles ? 'position-center' : '';
const stylesClass = params?.styles || '';

const needsBanner = isEditing
  ? true
  : (bannerText?.value !== '' || bannerCTA?.value?.href !== '');
---

{fields ? (
  <section
    data-component="Hero"
    class="@container/herowrapper bg-background text-foreground w-full overflow-hidden"
  >
    <div
      class:list={[
        '@md/herowrapper:pt-16 group relative pt-8',
        positionClass,
        stylesClass,
      ]}
    >
      <div class="@lg/herowrapper:max-w-[1216px] @lg/herowrapper:mx-10 @xl/herowrapper:mx-auto @md/herowrapper:pb-20 flex flex-col px-5 pb-8">
        <div class="flex flex-col items-center group-[.position-left]:items-start group-[.position-right]:items-end">
          {/* Title */}
          <astro-animated-section
            data-direction="up"
            data-editing={isEditing ? "true" : undefined}
            class="relative z-20"
          >
            <Text
              tag="h1"
              field={title}
              class="font-heading @md/herowrapper:text-[clamp(3rem,6cqi,6rem)] relative -ml-[2px] max-w-[15ch] text-balance text-5xl font-light leading-tight"
            />
          </astro-animated-section>

          {/* Description */}
          <astro-animated-section
            data-direction="up"
            data-delay="200"
            data-editing={isEditing ? "true" : undefined}
            class="mt-4 max-w-xl"
          >
            {description && (
              <Text
                tag="p"
                class="@md/herowrapper:text-xl max-w-[32ch] text-pretty leading-tight"
                field={description}
              />
            )}
          </astro-animated-section>

          {/* Form */}
          <astro-animated-section
            data-direction="up"
            data-delay="400"
            data-editing={isEditing ? "true" : undefined}
            class="mt-6 w-full"
          >
            <ZipcodeSearchForm
              placeholder={dictionary?.ZipPlaceholder || 'Enter your zipcode.'}
              buttonText={dictionary?.SubmitCTALabel || 'Find Availability'}
              searchLinkHref={searchLink?.value?.href || ''}
            />
          </astro-animated-section>
        </div>
      </div>

      {/* Full width image */}
      {image?.value?.src && (
        <div class="w-full">
          <div class="image-container relative w-full aspect-[144/56] before:block before:w-full before:absolute before:-top-[1px] before:left-0 before:right-0 before:h-[1px] before:bg-foreground before:z-10 overflow-hidden">
            <img
              src={image.value.src}
              alt={image.value.alt || ''}
              class="absolute aspect-[144/56] w-full object-cover"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
      )}

      {/* Banner */}
      {needsBanner && (
        <div class="@container/herobanner bg-primary text-primary-foreground @xl/herowrapper:w-1/2 @xl/herowrapper:absolute @xl/herowrapper:bottom-0 @xl/herowrapper:left-0 @xl/herowrapper:max-w-[45rem] @xl/herowrapper:group-[.position-right]:left-auto @xl/herowrapper:group-[.position-right]:right-0 w-full">
          <div class="@[35rem]/herobanner:flex-row @[35rem]/herobanner:items-center @[35rem]/herobanner:justify-between @[35rem]/herobanner:flex @[35rem]/herobanner:gap-10 @[35rem]/herobanner:text-left @md/herowrapper:max-w-screen-md @xl/herowrapper:max-w-none mx-auto p-5">
            {bannerText && (
              <astro-animated-section
                data-direction="up"
                data-editing={isEditing ? "true" : undefined}
              >
                <Text
                  tag="p"
                  class="font-heading @md/herowrapper:text-lg text-pretty font-light leading-tight"
                  field={bannerText}
                />
              </astro-animated-section>
            )}
            {bannerCTA?.value?.href && (
              <astro-animated-section
                data-direction="up"
                data-delay="200"
                data-editing={isEditing ? "true" : undefined}
                class="@[35rem]/herobanner:mt-0 mt-4"
              >
                {isEditing ? (
                  <Link
                    field={bannerCTA}
                    class="inline-flex items-center justify-center rounded-md bg-secondary px-4 py-2 text-sm font-medium text-secondary-foreground hover:bg-secondary/80"
                  />
                ) : (
                  <a
                    href={bannerCTA.value.href}
                    class="inline-flex items-center justify-center rounded-md bg-secondary px-4 py-2 text-sm font-medium text-secondary-foreground hover:bg-secondary/80"
                  >
                    {bannerCTA.value.text}
                  </a>
                )}
              </astro-animated-section>
            )}
          </div>
        </div>
      )}
    </div>
  </section>
) : (
  <div class="is-empty-hint">Hero</div>
)}

<script>
  import '@/scripts/animated-section';
</script>
