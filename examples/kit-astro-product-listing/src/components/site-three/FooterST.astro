---
import Text from "@exdst-sitecore-content-sdk/astro/components/Text.astro";
import RichText from "@exdst-sitecore-content-sdk/astro/components/RichText.astro";
import Link from "@exdst-sitecore-content-sdk/astro/components/Link.astro";
import Placeholder from "@exdst-sitecore-content-sdk/astro/components/Placeholder/Placeholder.astro";
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const variant = params?.FieldNames || "Default";
const styles = params?.styles || "";
const dynamicId = params?.DynamicPlaceholderId;

const title = fields?.Title;
const copyrightText = fields?.CopyrightText;
const facebookLink = fields?.FacebookLink;
const instagramLink = fields?.InstagramLink;
const linkedinLink = fields?.LinkedinLink;

function hasValidLink(field: any): boolean {
  const href = field?.value?.href;
  return !!(href && href !== "#" && !href.startsWith("http://#"));
}
---

{variant === "LogoLeft" ? (
  <section
    class={`relative bg-primary pt-16 lg:pt-30 bg-cover bg-center ${styles}`}
    style="background-image: url('/footer-texture.webp')"
    data-class-change
  >
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2">
        <h2 class="text-4xl lg:text-7xl mb-10 lg:mb-0 uppercase">
          <Text field={title} />
        </h2>
        <div class="lg:flex justify-end items-start gap-12">
          <div class="mb-6 lg:mb-0 font-(family-name:--font-heading) uppercase text-2xl">
            <Placeholder name={`footer-primary-links-${dynamicId}`} rendering={rendering} />
          </div>
          <div class="font-(family-name:--font-accent) font-medium">
            <Placeholder name={`footer-secondary-links-${dynamicId}`} rendering={rendering} />
          </div>
        </div>
      </div>
      <div class="flex flex-col gap-4 items-center lg:flex-row lg:justify-between mt-8">
        <div class="flex justify-center gap-4">
          {hasValidLink(facebookLink) ? (
            <Link field={facebookLink} aria-label="Facebook">
