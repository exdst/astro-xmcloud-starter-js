---
import AstroImage from "@exdst-sitecore-content-sdk/astro/components/AstroImage.astro";
import Link from "@exdst-sitecore-content-sdk/astro/components/Link.astro";
import Placeholder from "@exdst-sitecore-content-sdk/astro/components/Placeholder/Placeholder.astro";
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const styles = params?.styles || "";
const dynamicId = params?.DynamicPlaceholderId;

const logo = fields?.Logo;
const supportLink = fields?.SupportLink;
const searchLink = fields?.SearchLink;
const cartLink = fields?.CartLink;

const navLinkClass = "block p-4 font-[family-name:var(--font-accent)] font-medium";

function hasValidLink(field: any): boolean {
  const href = field?.value?.href;
  return !!(href && href !== "#" && !href.startsWith("http://#"));
}

const hasValidSupportLink = hasValidLink(supportLink);
const hasValidSearchLink = hasValidLink(searchLink);
const hasValidCartLink = hasValidLink(cartLink);
const showSearchBox = !!(params as any)?.showSearchBox;
const showMiniCart = !!(params as any)?.showMiniCart;
---

<section class={styles} data-class-change>
  <div class="flex justify-between items-start">
    <a
      href="/"
      class="relative flex justify-center items-center grow-0 shrink-0 w-24 lg:w-32 h-24 lg:h-32 p-4 lg:p-6 bg-primary z-100"
    >
      <AstroImage field={logo} class="w-full h-full object-contain" loading="eager" />
    </a>

    <div
      class="relative flex [.partial-editing-mode_&]:flex-col-reverse justify-between items-start gap-10 grow max-w-7xl lg:px-4 bg-background"
      role="navigation"
    >
      <ul class="hidden lg:flex flex-row lg:[.partial-editing-mode_&]:!flex-col text-left bg-background">
        <Placeholder name={`header-navigation-${dynamicId}`} rendering={rendering} />
      </ul>
      <div class="basis-full lg:basis-auto lg:ml-auto">
        <ul class="flex">
          <li class="hidden lg:block">
            {hasValidSupportLink ? (
              <Link field={supportLink} class={navLinkClass} />
            ) : (
              <span class={navLinkClass}>{supportLink?.value?.text || "Support"}</span>
            )}
          </li>
          <li class="mr-auto lg:mr-0">
            {showSearchBox ? (
              <Placeholder name={`header-search-box-${dynamicId}`} rendering={rendering} />
            ) : hasValidSearchLink ? (
              <Link field={searchLink} class={navLinkClass} />
            ) : (
              <span class={navLinkClass}>{searchLink?.value?.text || "Search"}</span>
            )}
          </li>
          <Placeholder name={`header-mobile-menu-${dynamicId}`} rendering={rendering} />
          <li>
            {showMiniCart ? (
              <Placeholder name={`header-mini-cart-${dynamicId}`} rendering={rendering} />
            ) : hasValidCartLink ? (
              <Link field={cartLink} class="block p-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 576 512" fill="currentColor"><path d="M0 24C0 10.7 10.7 0 24 0H69.5c22 0 41.5 12.8 50.6 32h411c26.3 0 45.5 25 38.6 50.4l-41 152.3c-8.5 31.4-37 53.3-69.5 53.3H170.7l5.4 28.5c2.2 11.3 12.1 19.5 23.6 19.5H488c13.3 0 24 10.7 24 24s-10.7 24-24 24H199.7c-34.6 0-64.3-24.6-70.7-58.5L77.4 54.5c-.7-3.8-4-6.5-7.9-6.5H24C10.7 48 0 37.3 0 24zM128 464a48 48 0 1 1 96 0 48 48 0 1 1 -96 0zm336-48a48 48 0 1 1 0 96 48 48 0 1 1 0-96z"/></svg>
              </Link>
            ) : (
              <span class="block p-4" aria-label="Shopping cart">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 576 512" fill="currentColor"><path d="M0 24C0 10.7 10.7 0 24 0H69.5c22 0 41.5 12.8 50.6 32h411c26.3 0 45.5 25 38.6 50.4l-41 152.3c-8.5 31.4-37 53.3-69.5 53.3H170.7l5.4 28.5c2.2 11.3 12.1 19.5 23.6 19.5H488c13.3 0 24 10.7 24 24s-10.7 24-24 24H199.7c-34.6 0-64.3-24.6-70.7-58.5L77.4 54.5c-.7-3.8-4-6.5-7.9-6.5H24C10.7 48 0 37.3 0 24zM128 464a48 48 0 1 1 96 0 48 48 0 1 1 -96 0zm336-48a48 48 0 1 1 0 96 48 48 0 1 1 0-96z"/></svg>
              </span>
            )}
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
