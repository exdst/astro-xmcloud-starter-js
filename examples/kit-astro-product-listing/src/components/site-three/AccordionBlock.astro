---
import type { ComponentProps } from "@/lib/component-props";

const { rendering, params } = Astro.props as ComponentProps;
const variant = params?.FieldNames || "Default";
const styles = params?.styles || "";

const datasource = rendering?.fields?.data?.datasource;
const heading = datasource?.heading?.jsonValue?.value || "";
const description = datasource?.description?.jsonValue?.value || "";
const link = datasource?.link?.jsonValue;
const linkHref = link?.value?.href || "";
const linkText = link?.value?.text || "";

const items = (datasource?.children?.results ?? []).map((item: any) => ({
  id: item.id,
  heading: item.heading?.jsonValue?.value || "",
  description: item.description?.jsonValue?.value || "",
}));

function hasValidLink(href: string): boolean {
  return !!(href && href !== "#" && !href.startsWith("http://#"));
}
---

{datasource ? (
  variant === "TwoColumn" ? (
    <section class={`relative py-20 overflow-hidden ${styles}`} data-class-change>
      <span class="absolute top-1/3 -left-1/3 w-screen h-64 bg-primary opacity-50 blur-[400px] rotate-15 z-10"></span>
      <div class="relative container mx-auto px-4 z-20">
        <h2 class="text-2xl lg:text-5xl">{heading}</h2>
        <div class="grid lg:grid-cols-2 gap-x-12 my-12">
          {items.map((item) => (
            <details class="border-border mb-10 border-b group">
              <summary class="flex justify-between items-center py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <h3 class="text-base">{item.heading}</h3>
                <svg class="shrink-0 w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <div class="pb-4" set:html={item.description} />
            </details>
          ))}
        </div>
        <div class="grid lg:grid-cols-2 gap-x-12">
          <div class="flex flex-col lg:flex-row lg:justify-between items-start lg:items-center gap-6 self-center lg:col-start-2 p-5 bg-primary">
            <p class="text-sm">{description}</p>
            {hasValidLink(linkHref) ? (
              <a href={linkHref} class="btn btn-secondary btn-sharp">{linkText}</a>
            ) : linkText ? (
              <span class="btn btn-secondary btn-sharp inline-block">{linkText}</span>
            ) : null}
          </div>
        </div>
      </div>
    </section>
  ) : variant === "Vertical" ? (
    <section class={`relative py-20 overflow-hidden ${styles}`} data-class-change>
      <span class="absolute -top-20 w-screen h-64 bg-primary opacity-50 blur-[400px] z-10"></span>
      <div class="relative container mx-auto px-4 z-20">
        <div class="flex flex-col gap-12 max-w-3xl mx-auto">
          <h2 class="text-2xl lg:text-5xl text-center">{heading}</h2>
          <div>
            {items.map((item) => (
              <details class="border-border mb-10 border-b group">
                <summary class="flex justify-between items-center py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                  <h3 class="text-base">{item.heading}</h3>
                  <svg class="shrink-0 w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </summary>
                <div class="pb-4" set:html={item.description} />
              </details>
            ))}
          </div>
          <div class="flex flex-col lg:flex-row lg:justify-between items-start lg:items-center gap-6 self-center p-5 bg-primary w-full">
            <p class="text-sm">{description}</p>
            {hasValidLink(linkHref) ? (
              <a href={linkHref} class="btn btn-secondary btn-sharp">{linkText}</a>
            ) : linkText ? (
              <span class="btn btn-secondary btn-sharp inline-block">{linkText}</span>
            ) : null}
          </div>
        </div>
      </div>
    </section>
  ) : variant === "BoxedAccordion" ? (
    <section class={`bg-primary py-20 ${styles}`} data-class-change>
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-2xl lg:text-5xl">{heading}</h2>
        </div>
        <div class="flex flex-col gap-12 max-w-3xl mx-auto bg-white p-4 lg:p-12 mt-12 shadow-2xl">
          <div>
            {items.map((item) => (
              <details class="border-border mb-10 border-b group">
                <summary class="flex justify-between items-center py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                  <h3 class="text-base">{item.heading}</h3>
                  <svg class="shrink-0 w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </summary>
                <div class="pb-4" set:html={item.description} />
              </details>
            ))}
          </div>
          <div class="flex flex-col lg:flex-row lg:justify-between items-start lg:items-center gap-6 self-center p-5 bg-primary w-full">
            <p class="text-sm">{description}</p>
            {hasValidLink(linkHref) ? (
              <a href={linkHref} class="btn btn-secondary btn-sharp">{linkText}</a>
            ) : linkText ? (
              <span class="btn btn-secondary btn-sharp inline-block">{linkText}</span>
            ) : null}
          </div>
        </div>
      </div>
    </section>
  ) : variant === "BoxedContent" ? (
    <section class={`bg-gradient py-20 ${styles}`} data-class-change>
      <div class="container mx-auto px-4">
        <div class="bg-white p-4 lg:p-12 shadow-2xl">
          <div class="flex flex-col gap-12 max-w-5xl mx-auto">
            <h2 class="text-2xl lg:text-5xl max-w-2xl">{heading}</h2>
            <div>
              {items.map((item) => (
                <details class="border-border mb-10 border-b group">
                  <summary class="flex justify-between items-center py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                    <h3 class="text-base">{item.heading}</h3>
                    <svg class="shrink-0 w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                  </summary>
                  <div class="pb-4" set:html={item.description} />
                </details>
              ))}
            </div>
            <div class="flex flex-col lg:flex-row lg:justify-between items-start lg:items-center gap-6 self-center p-5 bg-primary w-full">
              <p class="text-sm">{description}</p>
              {hasValidLink(linkHref) ? (
                <a href={linkHref} class="btn btn-secondary btn-sharp">{linkText}</a>
              ) : linkText ? (
                <span class="btn btn-secondary btn-sharp inline-block">{linkText}</span>
              ) : null}
            </div>
          </div>
        </div>
      </div>
    </section>
  ) : (
    /* Default */
    <section class={`relative py-20 overflow-hidden ${styles}`} data-class-change>
      <span class="absolute top-1/3 -left-1/3 w-screen h-64 bg-primary opacity-50 blur-[400px] rotate-15 z-10"></span>
      <div class="relative container mx-auto px-4 z-20">
        <div class="grid lg:grid-cols-2 gap-12">
          <h2 class="text-2xl lg:text-5xl">{heading}</h2>
          <div>
            <div class="mb-12">
              {items.map((item) => (
                <details class="border-border mb-10 border-b group">
                  <summary class="flex justify-between items-center py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                    <h3 class="text-base">{item.heading}</h3>
                    <svg class="shrink-0 w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                  </summary>
                  <div class="pb-4" set:html={item.description} />
                </details>
              ))}
            </div>
            <div class="flex flex-col lg:flex-row lg:justify-between items-start lg:items-center gap-6 self-center lg:col-start-2 p-5 bg-primary">
              <p class="text-sm">{description}</p>
              {hasValidLink(linkHref) ? (
                <a href={linkHref} class="btn btn-secondary btn-sharp">{linkText}</a>
              ) : linkText ? (
                <span class="btn btn-secondary btn-sharp inline-block">{linkText}</span>
              ) : null}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
) : (
  <div class="is-empty-hint">Accordion Block</div>
)}
