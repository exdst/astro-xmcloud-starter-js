---
import type { ComponentProps } from "@/lib/component-props";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const cartLink = fields?.CartLink;

function hasValidLink(field: any): boolean {
  const href = field?.value?.href;
  return !!(href && href !== "#" && !href.startsWith("http://#"));
}

const hasValidCartLink = hasValidLink(cartLink);
const cartHref = cartLink?.value?.href || "#";
---

<mini-cart-st data-has-valid-link={hasValidCartLink ? "true" : "false"}>
  <button
    type="button"
    class="block p-4"
    aria-label="Shopping cart"
    data-cart-trigger
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 576 512" fill="currentColor"><path d="M0 24C0 10.7 10.7 0 24 0H69.5c22 0 41.5 12.8 50.6 32h411c26.3 0 45.5 25 38.6 50.4l-41 152.3c-8.5 31.4-37 53.3-69.5 53.3H170.7l5.4 28.5c2.2 11.3 12.1 19.5 23.6 19.5H488c13.3 0 24 10.7 24 24s-10.7 24-24 24H199.7c-34.6 0-64.3-24.6-70.7-58.5L77.4 54.5c-.7-3.8-4-6.5-7.9-6.5H24C10.7 48 0 37.3 0 24zM128 464a48 48 0 1 1 96 0 48 48 0 1 1 -96 0zm336-48a48 48 0 1 1 0 96 48 48 0 1 1 0-96z"/></svg>
  </button>

  <div
    class="fixed lg:absolute top-14 left-0 right-0 lg:top-full lg:left-0 lg:right-0 h-[calc(100vh-3.5rem)] lg:h-auto overflow-auto opacity-0 lg:translate-y-2 pointer-events-none bg-background transition-all duration-300 ease-in-out"
    data-cart-dropdown
  >
    <div class="pt-18 p-8 lg:pt-8">
      <h2 class="mb-4 uppercase">Your Cart</h2>
      <p class="mb-8">Your cart is currently empty.</p>
      {hasValidCartLink ? (
        <a href={cartHref} class="btn btn-primary btn-sharp">Go to Cart</a>
      ) : (
        <span class="btn btn-primary btn-sharp inline-block">Go to Cart</span>
      )}
    </div>
  </div>
</mini-cart-st>

<script>
  class MiniCartST extends HTMLElement {
    private isVisible = false;
    private trigger: HTMLElement | null;
    private dropdown: HTMLElement | null;

    constructor() {
      super();
      this.trigger = this.querySelector("[data-cart-trigger]");
      this.dropdown = this.querySelector("[data-cart-dropdown]");
    }

    connectedCallback() {
      this.trigger?.addEventListener("click", (e) => {
        e.preventDefault();
        this.toggle();
      });

      document.addEventListener("click", (e) => {
        if (!this.contains(e.target as Node) && this.isVisible) {
          this.hide();
        }
      });
    }

    toggle() {
      this.isVisible ? this.hide() : this.show();
    }

    show() {
      this.isVisible = true;
      if (this.dropdown) {
        this.dropdown.classList.remove("opacity-0", "lg:translate-y-2", "pointer-events-none");
        this.dropdown.classList.add("opacity-100", "translate-y-0", "pointer-events-auto");
      }
    }

    hide() {
      this.isVisible = false;
      if (this.dropdown) {
        this.dropdown.classList.add("opacity-0", "lg:translate-y-2", "pointer-events-none");
        this.dropdown.classList.remove("opacity-100", "translate-y-0", "pointer-events-auto");
      }
    }
  }

  customElements.define("mini-cart-st", MiniCartST);
</script>
