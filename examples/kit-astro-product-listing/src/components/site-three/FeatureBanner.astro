---
import type { ComponentProps } from "@/lib/component-props";
import Text from "@exdst-sitecore-content-sdk/astro/components/Text.astro";
import AstroImage from "@exdst-sitecore-content-sdk/astro/components/AstroImage.astro";

const { rendering, params } = Astro.props as ComponentProps;
const variant = params?.FieldNames || "Default";
const styles = params?.styles || "";

const datasource = rendering?.fields?.data?.datasource;
const items = datasource?.children?.results ?? [];
---

{datasource ? (
  variant === "Accent" ? (
    <section class={`py-16 border-t border-b border-border ${styles}`} data-class-change>
      <div class="bg-primary">
        <div class="container mx-auto px-4">
          <div class="flex flex-col lg:flex-row justify-between items-center gap-8 py-12">
            <h2 class="text-2xl lg:text-5xl uppercase">
              <Text field={datasource?.title?.jsonValue} />
            </h2>
            <div class="flex flex-wrap lg:flex-nowrap justify-center items-start gap-8">
              {items.map((item: any) => (
                <div class="flex flex-col items-center gap-1">
                  <AstroImage field={item?.image?.jsonValue} class="w-6 h-6 object-contain" />
                  <p class="text-base text-center">
                    <Text field={item?.heading?.jsonValue} />
                  </p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  ) : variant === "Vertical" ? (
    <section class={`py-16 ${styles}`} data-class-change>
      <div class="container mx-auto px-4">
        <div class="flex flex-col items-center gap-8 lg:gap-12 py-12 border-t border-b border-border">
          <h2 class="text-2xl lg:text-5xl uppercase">
            <Text field={datasource?.title?.jsonValue} />
          </h2>
          <div class="flex flex-wrap lg:flex-nowrap justify-center items-start gap-10">
            {items.map((item: any) => (
              <div class="flex flex-col items-center gap-1">
                <AstroImage field={item?.image?.jsonValue} class="w-6 h-6 object-contain" />
                <p class="text-base text-center">
                  <Text field={item?.heading?.jsonValue} />
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section class={`py-16 ${styles}`} data-class-change>
      <div class="container mx-auto px-4">
        <div class="flex flex-col lg:flex-row justify-between items-center gap-8 py-12 border-t border-b border-border">
          <h2 class="text-2xl lg:text-5xl uppercase">
            <Text field={datasource?.title?.jsonValue} />
          </h2>
          <div class="flex flex-wrap lg:flex-nowrap justify-center items-start gap-8">
            {items.map((item: any) => (
              <div class="flex flex-col items-center gap-1">
                <AstroImage field={item?.image?.jsonValue} class="w-6 h-6 object-contain" />
                <p class="text-base text-center">
                  <Text field={item?.heading?.jsonValue} />
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
) : (
  <div class="is-empty-hint">Feature Banner</div>
)}
