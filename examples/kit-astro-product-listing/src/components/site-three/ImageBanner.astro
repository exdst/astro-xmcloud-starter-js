---
import Text from "@exdst-sitecore-content-sdk/astro/components/Text.astro";
import RichText from "@exdst-sitecore-content-sdk/astro/components/RichText.astro";
import AstroImage from "@exdst-sitecore-content-sdk/astro/components/AstroImage.astro";
import type { ComponentProps } from "@/lib/component-props";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const variant = params?.FieldNames || "Default";
const styles = params?.styles || "";

const title = fields?.Title;
const body = fields?.Body;
const image1 = fields?.Image1;
const image2 = fields?.Image2;
const image3 = fields?.Image3;
---

{variant === "Grid" ? (
  <section class={`relative py-16 ${styles}`} data-class-change>
    <div class="container px-4 mx-auto">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl lg:text-5xl uppercase mb-6">
          <Text field={title} />
        </h2>
        <div class="text-lg">
          <RichText field={body} />
        </div>
      </div>
      <div class="grid grid-cols-16 mt-16">
        <div class="aspect-8/3 col-span-9">
          <AstroImage field={image1} class="w-full h-full object-cover shadow-2xl rotate-0 hover:rotate-4 transition-transform" />
        </div>
        <div class="col-span-7 row-span-2">
          <AstroImage field={image2} class="w-full h-full object-cover shadow-2xl rotate-0 hover:rotate-4 transition-transform" />
        </div>
        <div class="aspect-4/3 col-span-9">
          <AstroImage field={image3} class="w-full h-full object-cover shadow-2xl rotate-0 hover:-rotate-4 transition-transform" />
        </div>
      </div>
    </div>
  </section>
) : variant === "FullWidthRow" ? (
  <section class={`relative py-16 ${styles}`} data-class-change>
    <div class="container px-4 mx-auto">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl lg:text-5xl uppercase mb-6">
          <Text field={title} />
        </h2>
        <div class="text-lg">
          <RichText field={body} />
        </div>
      </div>
    </div>
    <div class="grid grid-cols-24 mt-16">
      <div class="col-span-7 h-64 lg:h-84">
        <AstroImage field={image1} class="w-full h-full object-cover shadow-2xl rotate-0 hover:-rotate-4 transition-transform" />
      </div>
      <div class="col-span-10 h-64 lg:h-84">
        <AstroImage field={image2} class="w-full h-full object-cover shadow-2xl rotate-0 hover:rotate-4 transition-transform" />
      </div>
      <div class="col-span-7 h-64 lg:h-84">
        <AstroImage field={image3} class="w-full h-full object-cover shadow-2xl rotate-0 hover:-rotate-4 transition-transform" />
      </div>
    </div>
  </section>
) : variant === "SingleRowGrid" ? (
  <section class={`relative py-16 ${styles}`} data-class-change>
    <div class="container px-4 mx-auto">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl lg:text-5xl uppercase mb-6">
          <Text field={title} />
        </h2>
        <div class="text-lg">
          <RichText field={body} />
        </div>
      </div>
      <div class="grid grid-cols-10 gap-4 mt-16">
        <div class="col-span-3 h-64 lg:h-84 mt-10">
          <AstroImage field={image1} class="w-full h-full object-cover shadow-2xl rotate-0 hover:rotate-4 transition-transform" />
        </div>
        <div class="col-span-4 h-64 lg:h-84">
          <AstroImage field={image2} class="w-full h-full object-cover shadow-2xl rotate-0 hover:rotate-4 transition-transform" />
        </div>
        <div class="col-span-3 h-64 lg:h-84 mt-10">
          <AstroImage field={image3} class="w-full h-full object-cover shadow-2xl rotate-0 hover:-rotate-4 transition-transform" />
        </div>
      </div>
    </div>
  </section>
) : variant === "Stacked" ? (
  <section class={`relative py-16 ${styles}`} data-class-change>
    <div class="container px-4 mx-auto">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl lg:text-5xl uppercase mb-6">
          <Text field={title} />
        </h2>
        <div class="text-lg">
          <RichText field={body} />
        </div>
      </div>
    </div>
    <div class="container mx-auto sm:px-4">
      <div class="grid grid-cols-12 items-center gap-y-4 sm:gap-y-8 md:gap-y-10 lg:gap-y-16 mt-16">
        <div class="col-span-5 aspect-square">
          <AstroImage field={image1} class="w-full h-full object-cover shadow-2xl -rotate-1 hover:rotate-4 translate-x-1 transition-transform" />
        </div>
        <div class="col-span-6 col-start-7 aspect-square">
          <AstroImage field={image2} class="w-full h-full object-cover shadow-2xl rotate-4 hover:-rotate-4 -translate-x-4 transition-transform" />
        </div>
        <div class="col-span-7 col-start-3 aspect-square">
          <AstroImage field={image3} class="w-full h-full object-cover shadow-2xl -rotate-3 hover:rotate-3 transition-transform" />
        </div>
      </div>
    </div>
  </section>
) : (
  <!-- Default variant -->
  <section class={`relative py-16 ${styles}`} data-class-change>
    <div class="container px-4 mx-auto">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl lg:text-5xl uppercase mb-6">
          <Text field={title} />
        </h2>
        <div class="text-lg">
          <RichText field={body} />
        </div>
      </div>
    </div>
    <div class="container mx-auto sm:px-4">
      <div class="grid grid-cols-3 items-center mt-16">
        <div class="aspect-11/10">
          <AstroImage field={image1} class="w-full h-full object-cover shadow-2xl -rotate-4 hover:rotate-4 translate-x-4 lg:translate-x-8 transition-transform" />
        </div>
        <div class="aspect-9/10">
          <AstroImage field={image2} class="w-full h-full object-cover shadow-2xl rotate-0 hover:rotate-4 transition-transform" />
        </div>
        <div class="aspect-11/10">
          <AstroImage field={image3} class="w-full h-full object-cover shadow-2xl rotate-4 hover:-rotate-4 -translate-x-4 lg:-translate-x-8 transition-transform" />
        </div>
      </div>
    </div>
  </section>
)}
