---
import type { ComponentProps } from "@/lib/component-props";

const { rendering, params } = Astro.props as ComponentProps;
const styles = params?.styles || "";

const datasource = rendering?.fields?.data?.datasource;
const images = (datasource?.imageItems?.results ?? []).map((item: any) => ({
  id: item.id,
  imageSrc: item.image?.jsonValue?.value?.src || "",
  imageAlt: item.image?.jsonValue?.value?.alt || "",
}));

const bgImageSrc = images?.[0]?.imageSrc || "";

const carouselButtonStyles =
  "flex justify-center items-center absolute top-1/2 -translate-y-1/2 h-8 w-8 lg:h-10 lg:w-10 bg-primary hover:bg-primary-hover cursor-pointer disabled:pointer-events-none disabled:opacity-50";
---

{images.length > 0 ? (
  <image-carousel data-count={images.length}>
    <section
      class:list={[`relative bg-cover`, styles]}
      style={`background-image: linear-gradient(136deg, #ffffff14 2.61%, #ffffff26 73.95%), url(${bgImageSrc});`}
      data-class-change
    >
      <div class="backdrop-blur-md backdrop-grayscale backdrop-brightness-30">
        <div class="container mx-auto px-4 pt-8 lg:pt-16 lg:pb-8 flex flex-col gap-4">
          <div class="relative">
            <div class="overflow-hidden" data-main-viewport>
              <div class="flex touch-pan-y transition-transform duration-300 ease-out" data-main-track>
                {images.map((item) => (
                  <div class="w-full relative aspect-2/1 flex-shrink-0">
                    <img
                      src={item.imageSrc}
                      alt={item.imageAlt}
                      class="w-full h-full object-cover object-center"
                    />
                  </div>
                ))}
              </div>
            </div>
            <button
              data-prev
              disabled
              class={`-left-4 lg:-left-5 ${carouselButtonStyles}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            </button>
            <button
              data-next
              class={`-right-4 lg:-right-5 ${carouselButtonStyles}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </div>

          <div class="overflow-hidden w-full max-w-4xl px-4 mx-auto -translate-y-8" data-thumb-viewport>
            <div class="flex gap-2 transition-transform duration-300 ease-out" data-thumb-track>
              {images.map((item, index) => (
                <div
                  class:list={[
                    "w-[calc((100%-0.5rem*3)/3)] lg:w-[calc((100%-0.5rem*3)/4)] flex-shrink-0 cursor-pointer overflow-hidden border transition-all mt-6",
                    index === 0
                      ? "border-primary -translate-y-6"
                      : "border-transparent",
                  ]}
                  data-thumb-index={index}
                >
                  <img
                    src={item.imageSrc}
                    alt={item.imageAlt}
                    class="w-full h-full aspect-2/1 object-cover"
                  />
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </image-carousel>
) : (
  <div class="is-empty-hint">Image Carousel</div>
)}

<script>
  class ImageCarousel extends HTMLElement {
    private index = 0;
    private count = 0;
    private track!: HTMLElement;
    private thumbTrack!: HTMLElement;
    private thumbViewport!: HTMLElement;
    private prevBtn!: HTMLButtonElement;
    private nextBtn!: HTMLButtonElement;
    private thumbs!: HTMLElement[];

    // drag state
    private dragging = false;
    private startX = 0;
    private currentTranslate = 0;
    private dragDelta = 0;

    connectedCallback() {
      this.count = Number(this.dataset.count) || 0;
      if (this.count === 0) return;

      this.track = this.querySelector("[data-main-track]")!;
      this.thumbTrack = this.querySelector("[data-thumb-track]")!;
      this.thumbViewport = this.querySelector("[data-thumb-viewport]")!;
      this.prevBtn = this.querySelector("[data-prev]")!;
      this.nextBtn = this.querySelector("[data-next]")!;
      this.thumbs = Array.from(this.querySelectorAll("[data-thumb-index]"));

      this.prevBtn.addEventListener("click", () => this.goTo(this.index - 1));
      this.nextBtn.addEventListener("click", () => this.goTo(this.index + 1));

      this.thumbs.forEach((thumb) => {
        thumb.addEventListener("click", () => {
          this.goTo(Number(thumb.dataset.thumbIndex));
        });
      });

      // touch/drag on main track
      const viewport = this.querySelector("[data-main-viewport]")!;
      viewport.addEventListener("pointerdown", (e) => this.onDragStart(e as PointerEvent));
      viewport.addEventListener("pointermove", (e) => this.onDragMove(e as PointerEvent));
      viewport.addEventListener("pointerup", () => this.onDragEnd());
      viewport.addEventListener("pointercancel", () => this.onDragEnd());

      this.updateButtons();
    }

    private goTo(i: number) {
      const next = Math.max(0, Math.min(i, this.count - 1));
      if (next === this.index && i !== next) return;
      this.index = next;
      this.updateTrack();
      this.updateThumbs();
      this.updateButtons();
      this.scrollThumbIntoView();
    }

    private updateTrack() {
      this.track.style.transform = `translateX(-${this.index * 100}%)`;
    }

    private updateThumbs() {
      this.thumbs.forEach((thumb, idx) => {
        if (idx === this.index) {
          thumb.classList.add("border-primary", "-translate-y-6");
          thumb.classList.remove("border-transparent");
        } else {
          thumb.classList.remove("border-primary", "-translate-y-6");
          thumb.classList.add("border-transparent");
        }
      });
    }

    private updateButtons() {
      this.prevBtn.disabled = this.index === 0;
      this.nextBtn.disabled = this.index === this.count - 1;
    }

    private scrollThumbIntoView() {
      const thumb = this.thumbs[this.index];
      if (!thumb) return;
      const vpRect = this.thumbViewport.getBoundingClientRect();
      const thumbRect = thumb.getBoundingClientRect();

      if (thumbRect.left < vpRect.left || thumbRect.right > vpRect.right) {
        const offset = thumb.offsetLeft - this.thumbViewport.offsetWidth / 2 + thumb.offsetWidth / 2;
        this.thumbTrack.style.transform = `translateX(-${Math.max(0, offset)}px)`;
      }
    }

    // --- drag / touch ---
    private onDragStart(e: PointerEvent) {
      this.dragging = true;
      this.startX = e.clientX;
      this.dragDelta = 0;
      this.track.style.transition = "none";
      (e.currentTarget as HTMLElement).setPointerCapture(e.pointerId);
    }

    private onDragMove(e: PointerEvent) {
      if (!this.dragging) return;
      this.dragDelta = e.clientX - this.startX;
      const base = -this.index * this.track.parentElement!.offsetWidth;
      this.track.style.transform = `translateX(${base + this.dragDelta}px)`;
    }

    private onDragEnd() {
      if (!this.dragging) return;
      this.dragging = false;
      this.track.style.transition = "";
      const threshold = this.track.parentElement!.offsetWidth * 0.2;

      if (this.dragDelta < -threshold) {
        this.goTo(this.index + 1);
      } else if (this.dragDelta > threshold) {
        this.goTo(this.index - 1);
      } else {
        this.updateTrack();
      }
    }
  }

  customElements.define("image-carousel", ImageCarousel);
</script>
