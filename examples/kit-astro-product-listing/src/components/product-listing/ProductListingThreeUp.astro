---
import type { ComponentProps } from "@/lib/component-props";
import { useDictionary } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const t = useDictionary();

const datasource = fields?.data?.datasource;
const title = datasource?.title?.jsonValue?.value || "";
const viewAllLink = datasource?.viewAllLink?.jsonValue?.value || {};

const products = (datasource?.products?.targetItems ?? []).map((item: any) => ({
  productName: item.productName?.jsonValue?.value || "",
  productThumbnail: item.productThumbnail?.jsonValue?.value?.src || "",
  productThumbnailAlt: item.productThumbnail?.jsonValue?.value?.alt || "",
  productBasePrice: item.productBasePrice?.jsonValue?.value || "",
  productFeatureTitle: item.productFeatureTitle?.jsonValue?.value || "",
  productFeatureText: item.productFeatureText?.jsonValue?.value || "",
  productDrivingRange: item.productDrivingRange?.jsonValue?.value || "",
  url: item.url?.path || "",
}));

const styles = params?.styles || "";
const d = {
  drivingRange: t("Demo2_ProductListing_DrivingRange") || "Driving Range",
  seeFullSpecs: t("Demo2_ProductListing_SeeFullSpecs") || "See Full Specs",
  price: t("Demo2_ProductListing_Price") || "Starting at",
};
const viewAllHref = viewAllLink.href || "";
const viewAllText = viewAllLink.text || "";
---

{products.length > 0 && (
  <section
    class={`@container @md:px-6 mx-auto max-w-screen-xl border-b-2 border-t-2 py-12 [.border-b-2+&]:border-t-0 ${styles}`}
    aria-labelledby="product-listing-threeup-heading"
    data-product-spotlight
  >
    <div class="mb-12 flex flex-col items-start justify-between">
      <h2 id="product-listing-threeup-heading" class="w-full text-pretty text-5xl font-light tracking-tight antialiased">{title}</h2>
    </div>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {products.map((product) => (
        <div class="transition-all duration-500 ease-in-out h-full" data-spotlight-card>
          <div class="rounded-default duration-400 bg-secondary group relative self-stretch transition-all h-full w-full">
            <div class="relative z-[2] flex h-full w-full transition-all duration-300">
              <article class="@md:px-12 @md:py-12 font-heading relative z-10 flex w-full flex-col gap-8 px-6 py-10">
                <div class="relative overflow-hidden">
                  {product.productThumbnail && <img src={product.productThumbnail} alt={product.productThumbnailAlt} class="mx-auto" />}
                </div>
                <div class="space-y-6">
                  <div class="space-y-2">
                    <h3 class="text-secondary-foreground text-2xl font-semibold">{product.productName}</h3>
                    {product.productBasePrice && <p class="text-muted-foreground text-base font-light">{d.price} {product.productBasePrice}</p>}
                  </div>
                  <div class="border-muted-foreground border-t pt-4">
                    <h4 class="text-secondary-foreground font-regular text-xl mb-2">{product.productFeatureTitle}</h4>
                    <p class="text-muted-foreground text-sm font-light whitespace-pre-line">{product.productFeatureText}</p>
                  </div>
                  <div class="border-muted-foreground border-t pt-4">
                    <h4 class="text-secondary-foreground font-regular text-xl">{product.productDrivingRange}</h4>
                    <p class="text-muted-foreground text-sm font-light">{d.drivingRange}</p>
                  </div>
                  <div class="space-y-2 pt-2">
                    {viewAllHref && <a href={viewAllHref} class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground w-full">{viewAllText}</a>}
                    {product.url && <a href={product.url} class="inline-flex items-center justify-center whitespace-nowrap rounded-md border border-input bg-transparent px-4 py-2 text-sm font-medium w-full">{d.seeFullSpecs}</a>}
                  </div>
                </div>
              </article>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<script>
  document.querySelectorAll('[data-product-spotlight]').forEach((section) => {
    const cards = section.querySelectorAll('[data-spotlight-card]');
    cards.forEach((card) => {
      card.addEventListener('mouseenter', () => {
        cards.forEach((c) => {
          if (c !== card) {
            (c as HTMLElement).style.opacity = '0.5';
            (c as HTMLElement).style.transform = 'scale(0.95)';
            (c as HTMLElement).style.filter = 'blur(2px)';
          } else {
            (c as HTMLElement).style.transform = 'scale(1.05)';
            (c as HTMLElement).style.zIndex = '10';
          }
        });
      });
      card.addEventListener('mouseleave', () => {
        cards.forEach((c) => {
          (c as HTMLElement).style.opacity = '';
          (c as HTMLElement).style.transform = '';
          (c as HTMLElement).style.filter = '';
          (c as HTMLElement).style.zIndex = '';
        });
      });
    });
  });
</script>
