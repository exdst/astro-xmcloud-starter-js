---
import Text from "@/components/shared/AppText.astro";
import Link from "@exdst-sitecore-content-sdk/astro/components/Link.astro";
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const datasource = rendering?.fields?.data?.datasource;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const title = datasource?.title?.jsonValue;
const children = datasource?.children?.results ?? [];
const backgroundTheme = (params as any)?.backgroundTheme;
const showMeteors = backgroundTheme === 'shooting-star';

// Generate meteor data server-side
const meteorCount = 40;
const meteors = showMeteors ? Array.from({ length: meteorCount }, (_, i) => ({
  id: i,
  left: Math.floor(Math.random() * 100),
  delay: (Math.random() * 1.3 + 0.2).toFixed(2),
  duration: (Math.floor(Math.random() * 20) + 18).toString(),
})) : [];
---

{datasource ? (
  <div
    class="@container bg-primary text-primary-foreground relative overflow-hidden py-24 md:pb-[128px] md:pt-28"
    data-class-change
  >
    {showMeteors && (
      <div class="absolute inset-0 z-10 overflow-hidden">
        {meteors.map((m) => (
          <span
            class="meteor-particle pointer-events-none absolute rounded-full"
            style={`top: -5px; left: ${m.left}%; animation-delay: ${m.delay}s; animation-duration: ${m.duration}s;`}
          >
            <span class="meteor-tail pointer-events-none absolute top-1/2 -z-10 -translate-y-1/2"></span>
          </span>
        ))}
      </div>
    )}
    <div class="relative z-20 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center gap-16 text-center md:gap-24">
        <div class="flex max-w-4xl flex-col items-center gap-4">
          {title && (
            <Text
              tag="h2"
              field={title}
              class="font-heading @sm:text-5xl @md:text-6xl @lg:text-7xl text-4xl font-semibold leading-tight tracking-normal text-white"
            />
          )}
        </div>
        {children.length > 0 && (
          <div class="flex flex-wrap items-center justify-center gap-6">
            {children.map((topic: any) => {
              const linkField = topic?.link?.jsonValue;
              const href = linkField?.value?.href;
              const text = linkField?.value?.text;

              if (!isEditing && !href) return null;

              return isEditing ? (
                <Link
                  field={linkField}
                  class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-full bg-accent hover:bg-primary-hover text-accent-foreground font-heading py-2 text-sm font-medium transition-colors px-8 py-2-5"
                />
              ) : (
                <a
                  href={href}
                  class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-full bg-accent hover:bg-primary-hover text-accent-foreground font-heading py-2 text-sm font-medium transition-colors px-8 py-2-5"
                >
                  {text || 'Add link'}
                </a>
              );
            })}
          </div>
        )}
      </div>
    </div>
  </div>
) : (
  <div class="is-empty-hint">Topic Listing</div>
)}

<style is:global>
  .meteor-particle {
    width: 3px;
    height: 3px;
    background-color: rgba(255, 255, 255, 0.6);
    transform: rotate(250deg);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.1);
    animation: meteorAnimation linear infinite;
  }

  .meteor-tail {
    width: 100px;
    height: 1px;
    background-image: linear-gradient(to right, rgba(255, 255, 255, 0.6), transparent);
  }

  @keyframes meteorAnimation {
    0% {
      transform: rotate(250deg) translateX(0);
      opacity: 1;
    }
    70% {
      opacity: 1;
    }
    100% {
      transform: rotate(250deg) translateX(-500px);
      opacity: 0;
    }
  }
</style>
