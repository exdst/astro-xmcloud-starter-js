---
import Text from "@exdst-sitecore-content-sdk/astro/components/Text.astro";
import Link from "@exdst-sitecore-content-sdk/astro/components/Link.astro";
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering } = Astro.props as ComponentProps;
const datasource = rendering?.fields?.data?.datasource;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const header = datasource?.header?.jsonValue;
const items = datasource?.items?.results ?? [];
---

{datasource ? (
  <nav>
    {/* Mobile: accordion via details/summary */}
    <details class="footer-nav-column-mobile md:hidden w-full border-b">
      <summary class="flex cursor-pointer list-none items-center justify-between text-lg font-medium py-4 [&::-webkit-details-marker]:hidden">
        {header && <Text field={header} />}
        <svg class="h-4 w-4 transition-transform details-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>
      <ul class="space-y-2 py-2">
        {items.map((item: any) => (
          <li>
            <Link
              field={item.link?.jsonValue}
              class="h-auto text-pretty p-0 text-base font-normal text-white hover:underline"
            />
          </li>
        ))}
      </ul>
    </details>
    {/* Desktop: simple list */}
    <ul class="hidden md:block mt-6 space-y-6">
      {(isEditing || header?.value) && (
        <li class="text-lg font-medium">
          <Text field={header} />
        </li>
      )}
      {items.map((item: any) => (
        <li>
          <Link
            field={item.link?.jsonValue}
            class="h-auto text-pretty p-0 py-[10px] text-base font-normal text-white hover:underline inline-block"
          />
        </li>
      ))}
    </ul>
  </nav>
) : (
  <div class="is-empty-hint">Footer Navigation Column</div>
)}

<style>
  details[open] > summary svg {
    transform: rotate(180deg);
  }
</style>
