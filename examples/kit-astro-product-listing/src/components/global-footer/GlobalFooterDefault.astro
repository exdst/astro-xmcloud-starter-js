---
import Text from "@/components/shared/AppText.astro";
import Link from "@exdst-sitecore-content-sdk/astro/components/Link.astro";
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore, useDictionary } from "@exdst-sitecore-content-sdk/astro/context";
import { EmailSignupForm } from "@/components/forms/email/EmailSignupForm.tsx";

const { rendering } = Astro.props as ComponentProps;
const datasource = rendering?.fields?.data?.datasource;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;
const t = useDictionary();

const footerNavLinks = datasource?.footerNavLinks?.results ?? [];
const footerCopyright = datasource?.footerCopyright?.jsonValue;
const socialLinks = datasource?.socialLinks?.results ?? [];
const tagline = datasource?.tagline?.jsonValue;
const emailSubscriptionTitle = datasource?.emailSubscriptionTitle?.jsonValue;
const dictionary = rendering?.fields?.dictionary || {};
const globalDictionary = {
  FOOTER_EmailPlaceholder: t("Demo2_Footer_EmailPlaceholder") || dictionary?.FOOTER_EmailPlaceholder,
  FOOTER_EmailSubmitLabel: t("Demo2_Footer_EmailSubmitLabel") || dictionary?.FOOTER_EmailSubmitLabel,
  FOOTER_EmailErrorMessage: t("Demo2_Footer_EmailErrorMessage") || dictionary?.FOOTER_EmailErrorMessage,
  FOOTER_EmailSuccessMessage: t("Demo2_Footer_EmailSuccessMessage") || dictionary?.FOOTER_EmailSuccessMessage,
};
---

{datasource ? (
  <footer
    class="@container bg-primary text-primary-foreground border-foreground relative w-full overflow-hidden border-b-2"
    role="contentinfo"
  >
    {/* Main footer content */}
    <div class="border-foreground border-b-2 px-4 py-16">
      <div class="@xl:px-8 relative z-10 mx-auto max-w-screen-2xl">
        <div class="@lg:grid-cols-[2fr,1fr] grid grid-cols-1 items-end justify-end gap-8">
          {/* Left section with heading */}
          <div>
            {tagline && (
              <Text
                tag="h2"
                field={tagline}
                class="font-heading mb-8 text-pretty text-5xl font-light antialiased"
              />
            )}
            {/* Navigation links */}
            <nav>
              <ul class="-ml-4 flex list-none flex-wrap gap-4 p-0">
                {footerNavLinks.map((navLink: any) => {
                  const linkField = navLink?.link?.jsonValue;
                  const href = linkField?.value?.href;
                  const text = linkField?.value?.text;
                  return isEditing ? (
                    <li class="relative">
                      <Link field={linkField} class="font-heading inline-flex items-center justify-center whitespace-nowrap rounded-default bg-transparent px-4 py-2.5 text-lg font-medium leading-5 antialiased text-secondary-foreground hover:bg-transparent" />
                    </li>
                  ) : (
                    href && (
                      <li class="relative">
                        <a href={href} class="font-heading inline-flex items-center justify-center whitespace-nowrap rounded-default bg-transparent px-4 py-2.5 text-lg font-medium leading-5 antialiased text-secondary-foreground hover:bg-transparent">
                          {text}
                        </a>
                      </li>
                    )
                  );
                })}
              </ul>
            </nav>
          </div>

          {/* Right section with subscription form */}
          <div class="@md:max-w-[400px] ms-auto flex w-full flex-col gap-4">
            {emailSubscriptionTitle && (
              <Text
                class="font-body mb-4 text-xl font-medium"
                field={emailSubscriptionTitle}
              />
            )}
            <div class="@sm:flex-row flex flex-col gap-2">
              <EmailSignupForm
                client:visible
                emailPlaceholder={globalDictionary.FOOTER_EmailPlaceholder || "Email address"}
                emailSubmitLabel={globalDictionary.FOOTER_EmailSubmitLabel || "Subscribe"}
                emailErrorMessage={globalDictionary.FOOTER_EmailErrorMessage || "Please enter a valid email"}
                emailSuccessMessage={globalDictionary.FOOTER_EmailSuccessMessage || "Thank you!"}
                buttonVariant="secondary"
              />
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* Background logo - semi-transparent */}
    <div class="-z-1 pointer-events-none absolute inset-0 opacity-90" aria-hidden="true" data-component="footer-logo">
      <div class="flex h-full w-full items-end justify-center leading-none">
        <div class="bg-primary-gradient text-fill-transparent text-50-clamp -mb-14 bg-clip-text font-bold leading-none text-transparent">
          Alaris
        </div>
      </div>
    </div>

    {/* Bottom footer with social icons and copyright */}
    <div class="@md:min-h-[430px] relative z-0 mx-auto mt-8 flex max-w-screen-2xl flex-col justify-end px-4 py-8">
      <div class="@sm:flex-row flex flex-col items-center justify-between">
        {/* Social media icons */}
        <ul class="@sm:mb-0 mb-0 flex list-none gap-6">
          {socialLinks.map((socialLink: any) => {
            const linkField = socialLink?.link?.jsonValue;
            const iconField = socialLink?.socialIcon?.jsonValue;
            const href = linkField?.value?.href || '#';
            const text = linkField?.value?.text || '';
            return (
              <li>
                <a
                  href={href}
                  class="relative inline-flex h-10 w-10 items-center justify-center rounded-md hover:bg-transparent"
                  aria-label={text}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {iconField?.value?.src ? (
                    <img src={iconField.value.src} alt={text} class="h-6 w-6 object-contain" />
                  ) : (
                    <span class="text-sm">{text}</span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
        {/* Copyright text */}
        {footerCopyright && (
          <Text field={footerCopyright} />
        )}
      </div>
    </div>
  </footer>
) : (
  <div class="is-empty-hint">Global Footer</div>
)}
