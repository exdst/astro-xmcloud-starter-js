---
/**
 * ImageGallery - Dispatcher component
 * Routes to the appropriate gallery variant based on params.FieldNames.
 * Default variant matches ImageGallery.dev.tsx (asymmetric parallax-style layout).
 */
import ImageWrapper from "@/components/image/ImageWrapper.astro";
import Text from "@/components/shared/AppText.astro";
import ImageGalleryGrid from "./ImageGalleryGrid.astro";
import ImageGalleryFiftyFifty from "./ImageGalleryFiftyFifty.astro";
import ImageGalleryFeaturedImage from "./ImageGalleryFeaturedImage.astro";
import ImageGalleryNoSpacing from "./ImageGalleryNoSpacing.astro";
import type { ComponentProps } from "@/lib/component-props";
import type { Field } from "@exdst-sitecore-content-sdk/astro";

interface ImageGalleryFields {
  title?: Field<string>;
  description?: Field<string>;
  image1: any;
  image2: any;
  image3: any;
  image4: any;
}

interface Props extends ComponentProps {
  fields: ImageGalleryFields;
}

const props = Astro.props as Props;
const { fields, params } = props;
const variant = params?.FieldNames || "Default";
const { title, description, image1, image2, image3, image4 } = fields || {};
const styles = params?.styles || "";

const isVariant = (name: string) => variant === name;
---

{isVariant("Grid") ? (
  <ImageGalleryGrid {...props} />
) : isVariant("FiftyFifty") ? (
  <ImageGalleryFiftyFifty {...props} />
) : isVariant("FeaturedImage") ? (
  <ImageGalleryFeaturedImage {...props} />
) : isVariant("NoSpacing") ? (
  <ImageGalleryNoSpacing {...props} />
) : fields ? (
  <!-- Default variant: asymmetric layout -->
  <section
    class:list={[
      "@container group relative min-h-[100vh] max-w-screen-xl overflow-hidden",
      styles,
    ]}
    aria-label="Image gallery"
  >
    <div class="@xl:px-0 px-0 [&:not(.px-4_&):not(.px-6_&):not(.px-8_&):not(.px-10_&)]:px-6">
      <div class="relative mx-auto max-w-7xl py-16">
        <!-- Top row -->
        <div class="grid grid-cols-12 items-start gap-4">
          <!-- Top left image -->
          {image1 && (
            <figure class="@md:col-span-7 col-span-12">
              <button type="button" class="gallery-thumb block w-full cursor-zoom-in" data-index="0">
                <ImageWrapper image={image1} className="rounded-default h-auto w-full max-w-[581px]" />
              </button>
            </figure>
          )}

          <!-- Text content - Right side -->
          <div class="@md:col-span-6 @md:col-start-8 col-span-12 flex flex-col py-[160px] pt-0">
            {title && <Text tag="h2" field={title} />}
            {description && <Text tag="p" class="text-xl" field={description} />}
          </div>
        </div>

        <!-- Middle row -->
        <div class="grid grid-cols-12 gap-4">
          {image2 && (
            <figure class="@md:col-span-8 @md:col-start-6 z-10 col-span-12 -mt-[80px] mr-[70px]">
              <button type="button" class="gallery-thumb block w-full cursor-zoom-in" data-index="1">
                <ImageWrapper image={image2} className="rounded-default h-auto w-full max-w-[600px]" />
              </button>
            </figure>
          )}
        </div>

        <!-- Bottom row -->
        <div class="grid grid-cols-12 items-end gap-4">
          {image3 && (
            <figure class="@md:col-span-7 @md:col-start-1 col-span-12">
              <button type="button" class="gallery-thumb block w-full cursor-zoom-in" data-index="2">
                <ImageWrapper image={image3} className="rounded-default h-auto w-full" />
              </button>
            </figure>
          )}
          {image4 && (
            <figure class="@md:col-span-7 @md:col-start-8 col-span-12 items-end">
              <button type="button" class="gallery-thumb block w-full cursor-zoom-in" data-index="3">
                <ImageWrapper image={image4} className="rounded-default h-auto w-full" />
              </button>
            </figure>
          )}
        </div>
      </div>
    </div>

    <!-- Lightbox dialog -->
    <dialog class="gallery-lightbox backdrop:bg-black/80" aria-label="Image lightbox">
      <div class="relative flex h-full w-full items-center justify-center">
        <button type="button" class="lightbox-close absolute right-4 top-4 z-10 text-white text-3xl" aria-label="Close">&times;</button>
        <button type="button" class="lightbox-prev absolute left-4 z-10 text-white text-3xl" aria-label="Previous">&#8249;</button>
        <button type="button" class="lightbox-next absolute right-4 z-10 text-white text-3xl" aria-label="Next">&#8250;</button>
        <img class="lightbox-img max-h-[90vh] max-w-[90vw] object-contain" src="" alt="" />
      </div>
    </dialog>
  </section>
) : (
  <div class="component-no-data">ImageGallery: No data</div>
)}

<style>
  .gallery-lightbox {
    border: none;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    padding: 0;
  }
  .gallery-lightbox::backdrop {
    background: rgba(0, 0, 0, 0.8);
  }
</style>

<script>
  function initGallery(section: HTMLElement) {
    const dialog = section.querySelector<HTMLDialogElement>(".gallery-lightbox");
    const img = section.querySelector<HTMLImageElement>(".lightbox-img");
    const thumbs = section.querySelectorAll<HTMLButtonElement>(".gallery-thumb");
    if (!dialog || !img || !thumbs.length) return;

    const sources: string[] = [];
    thumbs.forEach((thumb) => {
      const imgEl = thumb.querySelector("img");
      if (imgEl) sources.push(imgEl.src);
    });

    let current = 0;
    function show(idx: number) {
      current = (idx + sources.length) % sources.length;
      img!.src = sources[current];
      if (!dialog!.open) dialog!.showModal();
    }

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => show(Number(thumb.dataset.index || 0)));
    });

    section.querySelector(".lightbox-close")?.addEventListener("click", () => dialog.close());
    section.querySelector(".lightbox-prev")?.addEventListener("click", () => show(current - 1));
    section.querySelector(".lightbox-next")?.addEventListener("click", () => show(current + 1));
    dialog.addEventListener("click", (e) => { if (e.target === dialog) dialog.close(); });
    dialog.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "ArrowLeft") show(current - 1);
      if (e.key === "ArrowRight") show(current + 1);
    });
  }

  document.querySelectorAll<HTMLElement>("section[aria-label='Image gallery']").forEach(initGallery);
</script>
