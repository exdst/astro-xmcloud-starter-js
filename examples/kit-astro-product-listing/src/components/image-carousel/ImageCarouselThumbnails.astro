---
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const datasource = fields?.data?.datasource;
const title = datasource?.title?.jsonValue?.value || "";

const slides = (datasource?.imageItems?.results ?? []).map((item: any) => ({
  image: item.image?.jsonValue?.value?.src || "",
  imageAlt: item.image?.jsonValue?.value?.alt || "",
  backgroundText: item.backgroundText?.jsonValue?.value || "",
  linkHref: item.link?.jsonValue?.value?.href || "",
  linkText: item.link?.jsonValue?.value?.text || "",
}));

const styles = params?.styles || "";
---

{slides.length > 0 && !isEditing && (
  <div
    class="@container bg-primary text-primary-foreground group relative flex w-full flex-col items-center justify-center py-16"
    role="region"
    aria-roledescription="carousel"
    data-component="ImageCarouselThumbnails"
  >
    <div class="mb-12 w-full space-y-4 px-4 group-[.position-center]:text-center group-[.position-right]:text-right">
      <h2 class="font-heading @md:text-6xl mx-auto max-w-[760px] text-pretty px-4 text-4xl font-light leading-none tracking-normal antialiased">
        {title}
      </h2>
    </div>

    <div class="sr-only" aria-live="polite" aria-atomic="true" data-carousel-live></div>

    <div class="w-full max-w-screen-xl mx-auto px-4">
      <div class="relative">
        <!-- Main carousel -->
        <div class="mb-4 w-full relative overflow-hidden" role="region" aria-roledescription="carousel">
          <div class="relative">
            {slides.map((slide, index) => (
              <div
                class:list={[
                  "w-full transition-opacity duration-500 ease-in-out",
                  index === 0 ? "relative opacity-100" : "absolute inset-0 opacity-0 pointer-events-none",
                ]}
                data-carousel-item
                data-index={index}
                role="group"
                aria-roledescription="slide"
                tabindex={index === 0 ? 0 : -1}
              >
                <div class="relative">
                  {slide.image && (
                    <img
                      src={slide.image}
                      alt={slide.imageAlt}
                      class="relative z-0 h-auto w-full rounded-lg overflow-hidden"
                      loading="lazy"
                    />
                  )}
                  <div
                    class:list={[
                      "absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-6 transition-opacity duration-500",
                      index === 0 ? "opacity-100" : "opacity-0",
                    ]}
                    data-slide-overlay
                  >
                    <p class="text-foreground text-4xl font-bold leading-none md:text-5xl">
                      {slide.backgroundText}
                    </p>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- Prev/Next over main image -->
          <button
            class="absolute top-1/2 transform -translate-y-1/2 z-10 left-4 inline-flex items-center justify-center rounded-md bg-secondary text-secondary-foreground h-10 w-10 hover:bg-secondary/80"
            data-carousel-prev
            aria-label="Previous slide"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button
            class="absolute top-1/2 transform -translate-y-1/2 z-10 right-4 inline-flex items-center justify-center rounded-md bg-secondary text-secondary-foreground h-10 w-10 hover:bg-secondary/80"
            data-carousel-next
            aria-label="Next slide"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>

        <!-- Thumbnail strip -->
        <div class="w-full overflow-hidden" data-thumb-viewport>
          <div class="flex gap-2 md:gap-4 transition-transform duration-300 ease-in-out" data-thumb-track>
            {slides.map((slide, index) => (
              <button
                class:list={[
                  "flex-shrink-0 basis-1/3 md:basis-1/5 cursor-pointer rounded-default transition-all duration-300",
                  index === 0 ? "scale-105 opacity-100" : "opacity-60",
                ]}
                data-thumb-item
                data-thumb-index={index}
                aria-label={`Go to slide ${index + 1}`}
              >
                {slide.image && (
                  <img
                    src={slide.image}
                    alt={slide.imageAlt}
                    class="h-auto w-full aspect-video object-contain"
                    loading="lazy"
                  />
                )}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 flex items-center justify-center">
      {slides.map((slide, index) => (
        <a
          href={slide.linkHref}
          class:list={[
            "inline-flex items-center justify-center rounded-md bg-secondary text-secondary-foreground px-4 py-2 text-sm font-medium hover:bg-secondary/80",
            "carousel-link",
            index === 0 ? "" : "hidden",
          ]}
          data-carousel-link
          data-link-index={index}
        >
          {slide.linkText}
        </a>
      ))}
    </div>
    <div class="sr-only">Use left and right arrow keys to navigate between slides.</div>
  </div>
)}

<script>
  document.querySelectorAll<HTMLElement>('[data-component="ImageCarouselThumbnails"]').forEach((container) => {
    const items = Array.from(container.querySelectorAll<HTMLElement>('[data-carousel-item]'));
    const overlays = Array.from(container.querySelectorAll<HTMLElement>('[data-slide-overlay]'));
    const links = Array.from(container.querySelectorAll<HTMLElement>('[data-carousel-link]'));
    const thumbs = Array.from(container.querySelectorAll<HTMLElement>('[data-thumb-item]'));
    const thumbTrack = container.querySelector<HTMLElement>('[data-thumb-track]');
    const liveRegion = container.querySelector<HTMLElement>('[data-carousel-live]');
    const prevBtn = container.querySelector<HTMLElement>('[data-carousel-prev]');
    const nextBtn = container.querySelector<HTMLElement>('[data-carousel-next]');

    if (!items.length) return;

    let current = 0;
    const total = items.length;

    function wrapIndex(i: number) { return ((i % total) + total) % total; }

    function updateSlide(index: number) {
      current = wrapIndex(index);

      // Update main slides
      items.forEach((el, i) => {
        const isActive = i === current;
        el.classList.toggle('opacity-100', isActive);
        el.classList.toggle('opacity-0', !isActive);
        el.classList.toggle('pointer-events-none', !isActive);
        el.classList.toggle('relative', isActive);
        el.classList.toggle('absolute', !isActive);
        el.classList.toggle('inset-0', !isActive);
        el.setAttribute('tabindex', isActive ? '0' : '-1');
      });

      // Update overlays
      overlays.forEach((overlay, i) => {
        overlay.classList.toggle('opacity-100', i === current);
        overlay.classList.toggle('opacity-0', i !== current);
      });

      // Update links
      links.forEach((link, i) => {
        link.classList.toggle('hidden', i !== current);
      });

      // Update thumbnails
      thumbs.forEach((thumb, i) => {
        const isActive = i === current;
        thumb.classList.toggle('scale-105', isActive);
        thumb.classList.toggle('opacity-100', isActive);
        thumb.classList.toggle('opacity-60', !isActive);
      });

      // Scroll thumbnail track
      if (thumbTrack && thumbs[current]) {
        const thumbEl = thumbs[current];
        const trackRect = thumbTrack.parentElement!.getBoundingClientRect();
        const scrollTarget = thumbEl.offsetLeft - (trackRect.width / 2) + (thumbEl.offsetWidth / 2);
        thumbTrack.style.transform = `translateX(${-Math.max(0, scrollTarget)}px)`;
      }

      if (liveRegion) {
        const bgText = items[current]?.querySelector('[data-slide-overlay] p')?.textContent || '';
        liveRegion.textContent = `Showing slide ${current + 1} of ${total}: ${bgText}.`;
      }
    }

    prevBtn?.addEventListener('click', () => updateSlide(current - 1));
    nextBtn?.addEventListener('click', () => updateSlide(current + 1));

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const idx = parseInt(thumb.getAttribute('data-thumb-index') || '0', 10);
        updateSlide(idx);
      });
    });

    container.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); updateSlide(current - 1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); updateSlide(current + 1); }
    });
  });
</script>
