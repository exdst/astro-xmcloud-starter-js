---
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;

const datasource = fields?.data?.datasource;
const title = datasource?.title?.jsonValue?.value || "";

const slides = (datasource?.imageItems?.results ?? []).map((item: any) => ({
  image: item.image?.jsonValue?.value?.src || "",
  imageAlt: item.image?.jsonValue?.value?.alt || "",
  backgroundText: item.backgroundText?.jsonValue?.value || "",
  linkHref: item.link?.jsonValue?.value?.href || "",
  linkText: item.link?.jsonValue?.value?.text || "",
}));

const styles = params?.styles || "";
---

{slides.length > 0 && (
  <div
    class="@container bg-primary group text-primary-foreground relative flex w-full flex-col items-center justify-center py-[99px]"
    data-component="ImageCarouselEditMode"
  >
    <div class="mb-8 w-full space-y-4 text-center">
      <h2 class="font-heading @md:text-5xl mx-auto max-w-[760px] text-pretty text-3xl font-light leading-none tracking-normal antialiased">
        {title}
      </h2>
    </div>
    <div class="mx-auto max-w-screen-xl space-y-6">
      <h3 class="border-primary-foreground/20 border-b pb-2 text-xl font-medium">Carousel Items:</h3>
      {slides.map((slide, index) => (
        <div class="overflow-hidden border-0 bg-transparent">
          <div class="flex flex-col items-stretch gap-4 p-4 md:flex-row">
            <div class="flex-shrink-0 md:w-1/3">
              {slide.image && (
                <img
                  src={slide.image}
                  alt={slide.imageAlt}
                  class="relative z-0 h-auto w-full overflow-hidden rounded-md"
                  loading="lazy"
                />
              )}
            </div>
            <div class="flex flex-col items-center justify-center md:w-1/3">
              <p class="bg-light-gradient text-fill-transparent bg-clip-text text-9xl font-bold leading-none text-transparent">
                {slide.backgroundText}
              </p>
            </div>
            <div class="flex flex-col items-center justify-center md:w-1/3">
              {slide.linkHref && (
                <a
                  href={slide.linkHref}
                  class="inline-flex items-center justify-center rounded-md border px-4 py-2"
                >
                  {slide.linkText}
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
)}
