---
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const datasource = fields?.data?.datasource;
const title = datasource?.title?.jsonValue?.value || "";

const slides = (datasource?.imageItems?.results ?? []).map((item: any) => ({
  image: item.image?.jsonValue?.value?.src || "",
  imageAlt: item.image?.jsonValue?.value?.alt || "",
  imageWidth: Number(item.image?.jsonValue?.value?.width) || undefined,
  imageHeight: Number(item.image?.jsonValue?.value?.height) || undefined,
  backgroundText: item.backgroundText?.jsonValue?.value || "",
  linkHref: item.link?.jsonValue?.value?.href || "",
  linkText: item.link?.jsonValue?.value?.text || "",
}));

const styles = params?.styles || "";
const hasPagesPositionStyles = styles ? styles.includes("position-") : false;
const containerPositionClass = hasPagesPositionStyles ? "" : "position-center";
const uniqueId = `carousel-default-${Math.random().toString(36).slice(2, 9)}`;
---

{slides.length > 0 && !isEditing && (
  <div
    class:list={[
      "@container group bg-primary text-primary-foreground relative flex w-full flex-col items-center justify-center py-[99px]",
      containerPositionClass,
      styles,
    ]}
    data-component="ImageCarouselDefault"
    data-carousel
    data-carousel-id={uniqueId}
  >
    <div class="w-full space-y-4 px-4 group-[.position-center]:text-center group-[.position-right]:text-right">
      <h2 class="font-heading @md:text-7xl mx-auto max-w-[760px] text-pretty px-4 text-5xl text-box-trim-bottom-baseline">
        {title}
      </h2>
    </div>

    <div class="sr-only" aria-live="polite" aria-atomic="true" data-carousel-live></div>

    <div class="w-full" data-component-part="carousel wrapper">
      <div class="w-full overflow-visible" role="region" aria-roledescription="carousel" aria-label={`Slideshow, 1 of ${slides.length}`}>
        <div class="sr-only" data-carousel-label>Slideshow, 1 of {slides.length}</div>
        <div class="-ml-[100px] h-full items-stretch flex" data-carousel-track>
          {slides.map((slide, index) => (
            <div
              class:list={[
                "@md:basis-4/5 @lg:basis-2/3 pointer-events-none flex h-full basis-full flex-col justify-stretch pl-[100px] @md:max-w-1/2 mx-auto flex-shrink-0",
                "carousel-slide transition-transform duration-500 ease-in-out",
              ]}
              data-carousel-item
              data-index={index}
              role="group"
              aria-roledescription="slide"
              aria-label={`${slide.backgroundText || ""}, ${index === 0 ? "current slide" : ""}`}
              tabindex={index === 0 ? 0 : -1}
            >
              <div class:list={[
                "@md:px-25 h-full w-full transform-gpu px-6 transition-all duration-500 ease-in-out",
                index === 0 ? "scale-100" : "scale-95",
              ]} data-slide-content>
                {slide.backgroundText && (
                  <div
                    class="flex h-full w-full items-center justify-center transition-all duration-700 ease-in-out"
                    data-bg-text-wrapper
                    style={`opacity: ${index === 0 ? 1 : 0}; filter: ${index === 0 ? "blur(0px)" : "blur(10px)"}; transform: ${index === 0 ? "scale(1)" : "scale(0.3)"}; transition-delay: 200ms;`}
                  >
                    <p class="bg-primary-gradient text-fill-transparent text-[100px] @md:text-40-clamp bg-clip-text font-bold leading-none text-transparent">
                      {slide.backgroundText}
                    </p>
                  </div>
                )}
              </div>
              {slide.image && (
                <img
                  src={slide.image}
                  alt={slide.imageAlt}
                  width={slide.imageWidth}
                  height={slide.imageHeight}
                  style="width: 100%; height: auto;"
                  class="relative z-0 h-auto w-full max-w-[860px] mx-auto"
                  loading="lazy"
                />
              )}
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-8 flex items-center gap-4" role="group" aria-label="Slideshow controls">
      <button
        class="inline-flex items-center justify-center rounded-md bg-secondary text-secondary-foreground h-10 w-10 hover:bg-secondary/80"
        data-carousel-prev
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      {slides.map((slide, index) => (
        <a
          href={slide.linkHref}
          class:list={[
            "inline-flex items-center justify-center rounded-md bg-secondary text-secondary-foreground px-4 py-2 text-sm font-medium hover:bg-secondary/80",
            "carousel-link",
            index === 0 ? "" : "hidden",
          ]}
          data-carousel-link
          data-link-index={index}
        >
          {slide.linkText}
        </a>
      ))}
      <button
        class="inline-flex items-center justify-center rounded-md bg-secondary text-secondary-foreground h-10 w-10 hover:bg-secondary/80"
        data-carousel-next
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
    <div class="sr-only">Use left and right arrow keys to navigate between slides.</div>
  </div>
)}

{slides.length > 0 && isEditing && (
  <Fragment set:html={`<!-- Edit mode: see ImageCarouselEditMode -->`} />
)}

<script>
  document.querySelectorAll<HTMLElement>('[data-component="ImageCarouselDefault"]').forEach((container) => {
    const items = Array.from(container.querySelectorAll<HTMLElement>('[data-carousel-item]'));
    const links = Array.from(container.querySelectorAll<HTMLElement>('[data-carousel-link]'));
    const liveRegion = container.querySelector<HTMLElement>('[data-carousel-live]');
    const prevBtn = container.querySelector<HTMLElement>('[data-carousel-prev]');
    const nextBtn = container.querySelector<HTMLElement>('[data-carousel-next]');
    const track = container.querySelector<HTMLElement>('[data-carousel-track]');

    if (!items.length || !track) return;

    let current = 0;
    const total = items.length;

    function updateSlide(index: number) {
      current = ((index % total) + total) % total;

      // Scroll track so the current item is centered
      const item = items[current];
      const trackRect = track!.getBoundingClientRect();
      const itemRect = item.getBoundingClientRect();
      const containerRect = container.getBoundingClientRect();
      const scrollTarget = item.offsetLeft - (containerRect.width / 2) + (item.offsetWidth / 2);
      track!.style.transform = `translateX(${-scrollTarget}px)`;
      track!.style.transition = 'transform 500ms ease-in-out';

      items.forEach((el, i) => {
        const content = el.querySelector<HTMLElement>('[data-slide-content]');
        const bgWrapper = el.querySelector<HTMLElement>('[data-bg-text-wrapper]');
        const isActive = i === current;

        el.setAttribute('tabindex', isActive ? '0' : '-1');
        el.setAttribute('aria-label', `${el.getAttribute('aria-label')?.split(',')[0] || ''}, ${isActive ? 'current slide' : ''}`);

        if (content) {
          content.classList.toggle('scale-100', isActive);
          content.classList.toggle('scale-95', !isActive);
        }
        if (bgWrapper) {
          bgWrapper.style.opacity = isActive ? '1' : '0';
          bgWrapper.style.filter = isActive ? 'blur(0px)' : 'blur(10px)';
          bgWrapper.style.transform = isActive ? 'scale(1)' : 'scale(0.3)';
        }
      });

      links.forEach((link, i) => {
        link.classList.toggle('hidden', i !== current);
      });

      if (liveRegion) {
        const bgText = items[current].querySelector('[data-bg-text-wrapper] p')?.textContent || '';
        liveRegion.textContent = `Showing slide ${current + 1} of ${total}: ${bgText}.`;
      }
    }

    // Initial position
    requestAnimationFrame(() => updateSlide(0));

    prevBtn?.addEventListener('click', () => updateSlide(current - 1));
    nextBtn?.addEventListener('click', () => updateSlide(current + 1));

    container.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); updateSlide(current - 1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); updateSlide(current + 1); }
    });
  });
</script>
