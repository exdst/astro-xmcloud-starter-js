---
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const datasource = fields?.data?.datasource;
const title = datasource?.title?.jsonValue?.value || "";

const slides = (datasource?.imageItems?.results ?? []).map((item: any) => ({
  image: item.image?.jsonValue?.value?.src || "",
  imageAlt: item.image?.jsonValue?.value?.alt || "",
  backgroundText: item.backgroundText?.jsonValue?.value || "",
  linkHref: item.link?.jsonValue?.value?.href || "",
  linkText: item.link?.jsonValue?.value?.text || "",
}));

const styles = params?.styles || "";
const hasPagesPositionStyles = styles ? styles.includes("position-") : false;
const containerPositionClass = hasPagesPositionStyles ? "" : "position-left";
---

{slides.length > 0 && !isEditing && (
  <div
    class:list={[
      "@container group bg-primary grid w-full grid-cols-1 gap-9",
      containerPositionClass,
      styles,
    ]}
    data-class-change
    data-component="ImageCarouselFullBleed"
  >
    <div class="mx-auto w-full max-w-screen-2xl px-4">
      <div class="@md:flex-row flex w-full flex-col items-end justify-between">
        <h2 class="font-heading text-pretty px-4 font-light leading-none tracking-normal antialiased">
          {title}
        </h2>
        <div class="@md:mt-0 mt-8 flex items-center justify-center">
          {slides.map((slide, index) => (
            <a
              href={slide.linkHref}
              class:list={[
                "inline-flex items-center justify-center rounded-md bg-secondary text-secondary-foreground px-4 py-2 text-sm font-medium hover:bg-secondary/80 mb-6",
                "carousel-link",
                index === 0 ? "" : "hidden",
              ]}
              data-carousel-link
              data-link-index={index}
            >
              {slide.linkText}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="sr-only" aria-live="polite" aria-atomic="true" data-carousel-live></div>

    <div class="relative w-full">
      <div class="w-full overflow-hidden" role="region" aria-roledescription="carousel">
        <div class="sr-only" data-carousel-label>Slideshow, 1 of {slides.length}</div>
        <div class="flex transition-transform duration-500 ease-in-out" data-carousel-track>
          {slides.map((slide, index) => (
            <div
              class="min-w-full flex-shrink-0"
              data-carousel-item
              data-index={index}
              role="group"
              aria-roledescription="slide"
              tabindex={index === 0 ? 0 : -1}
            >
              <div class="relative flex justify-center">
                <div class="w-full">
                  {slide.image && (
                    <img
                      src={slide.image}
                      alt={slide.imageAlt}
                      class="relative z-0 h-auto w-full object-cover"
                      loading="lazy"
                    />
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="absolute left-0 top-1/2 flex w-full">
        <div class="relative mx-auto w-full max-w-screen-2xl">
          <button
            class="border border-primary-foreground inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground h-10 w-10 hover:bg-primary/80 absolute top-1/2 z-20 -translate-y-1/2 left-4 -ms-4"
            data-carousel-prev
            aria-label="Previous slide"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button
            class="border border-primary-foreground inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground h-10 w-10 hover:bg-primary/80 absolute top-1/2 z-20 -translate-y-1/2 right-4 -me-4"
            data-carousel-next
            aria-label="Next slide"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    </div>
    <div class="sr-only">Use left and right arrow keys to navigate between slides.</div>
  </div>
)}

<script>
  document.querySelectorAll<HTMLElement>('[data-component="ImageCarouselFullBleed"]').forEach((container) => {
    const items = Array.from(container.querySelectorAll<HTMLElement>('[data-carousel-item]'));
    const links = Array.from(container.querySelectorAll<HTMLElement>('[data-carousel-link]'));
    const liveRegion = container.querySelector<HTMLElement>('[data-carousel-live]');
    const prevBtn = container.querySelector<HTMLElement>('[data-carousel-prev]');
    const nextBtn = container.querySelector<HTMLElement>('[data-carousel-next]');
    const track = container.querySelector<HTMLElement>('[data-carousel-track]');

    if (!items.length || !track) return;

    let current = 0;
    const total = items.length;

    function updateSlide(index: number) {
      current = ((index % total) + total) % total;
      track!.style.transform = `translateX(${-current * 100}%)`;

      items.forEach((el, i) => {
        el.setAttribute('tabindex', i === current ? '0' : '-1');
      });

      links.forEach((link, i) => {
        link.classList.toggle('hidden', i !== current);
      });

      if (liveRegion) {
        liveRegion.textContent = `Showing slide ${current + 1} of ${total}`;
      }
    }

    prevBtn?.addEventListener('click', () => updateSlide(current - 1));
    nextBtn?.addEventListener('click', () => updateSlide(current + 1));

    container.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); updateSlide(current - 1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); updateSlide(current + 1); }
    });
  });
</script>
