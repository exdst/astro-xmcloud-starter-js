---
import type { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@exdst-sitecore-content-sdk/astro/context";

const { rendering, params } = Astro.props as ComponentProps;
const fields = rendering?.fields;
const { page } = useSitecore();
const isEditing = page?.mode?.isEditing ?? false;

const datasource = fields?.data?.datasource;
const title = datasource?.title?.jsonValue?.value || "";

const slides = (datasource?.imageItems?.results ?? []).map((item: any) => ({
  image: item.image?.jsonValue?.value?.src || "",
  imageAlt: item.image?.jsonValue?.value?.alt || "",
  backgroundText: item.backgroundText?.jsonValue?.value || "",
  linkHref: item.link?.jsonValue?.value?.href || "",
  linkText: item.link?.jsonValue?.value?.text || "",
}));

const styles = params?.styles || "";
const hasPagesPositionStyles = styles ? styles.includes("position-") : false;
const containerPositionClass = hasPagesPositionStyles ? "" : "position-center";
---

{slides.length > 0 && !isEditing && (
  <div
    class:list={[
      "@container bg-background text-foreground group relative flex w-full flex-col items-center justify-center py-[99px]",
      containerPositionClass,
      styles,
    ]}
    role="region"
    data-component="ImageCarouselPreviewBelow"
  >
    <div class="mb-4 w-full space-y-4 px-4">
      <h2 class="font-heading @md:text-7xl mx-auto max-w-[760px] text-pretty px-4 text-5xl font-light leading-none tracking-normal antialiased group-[.position-left]:text-left group-[.position-center]:text-center group-[.position-right]:text-right">
        {title}
      </h2>
    </div>
    <div class="mb-12 flex justify-center">
      {slides.map((slide, index) => (
        <a
          href={slide.linkHref}
          class:list={[
            "inline-flex items-center justify-center rounded-md bg-foreground text-background px-4 py-2 text-sm font-medium hover:bg-foreground/80",
            "carousel-link",
            index === 0 ? "" : "hidden",
          ]}
          data-carousel-link
          data-link-index={index}
        >
          {slide.linkText}
        </a>
      ))}
    </div>

    <div class="sr-only" aria-live="polite" aria-atomic="true" data-carousel-live></div>

    <!-- Main carousel -->
    <div class="relative mx-auto w-full max-w-screen-xl px-4">
      <div class="w-full overflow-hidden" role="region" aria-roledescription="carousel">
        <div class="relative">
          {slides.map((slide, index) => (
            <div
              class:list={[
                "w-full transition-opacity duration-500 ease-in-out",
                index === 0 ? "relative opacity-100" : "absolute inset-0 opacity-0 pointer-events-none",
              ]}
              data-carousel-item
              data-index={index}
              role="group"
              aria-roledescription="slide"
              tabindex={index === 0 ? 0 : -1}
            >
              <div class="relative">
                {slide.image && (
                  <img
                    src={slide.image}
                    alt={slide.imageAlt}
                    class="relative z-0 h-auto w-full"
                    loading="lazy"
                  />
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Thumbnail strip with prev/next -->
    <div class="px-4 mt-4 @md:mt-0 @md:px-0 flex items-center justify-center gap-2 @md:gap-4 max-w-screen-xl mx-auto @md:-translate-y-1/2">
      <button
        class="inline-flex items-center justify-center rounded-md bg-foreground text-background h-10 w-10 hover:bg-foreground/80 flex-shrink-0"
        data-carousel-prev
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>

      <div class="w-full max-w-[390px] overflow-hidden" data-thumb-viewport>
        <div class="flex gap-2 transition-transform duration-300 ease-in-out" data-thumb-track>
          {slides.map((slide, index) => (
            <button
              class:list={[
                "flex-shrink-0 w-[calc(50%-4px)] border-2 transition-all duration-300",
                index === 0 ? "border-foreground" : "border-transparent",
              ]}
              data-thumb-item
              data-thumb-index={index}
              aria-label={`Go to slide ${index + 1}`}
              aria-current={index === 0 ? "true" : "false"}
            >
              {slide.image && (
                <img
                  src={slide.image}
                  alt={slide.imageAlt}
                  class="h-auto w-full"
                  loading="lazy"
                />
              )}
            </button>
          ))}
        </div>
      </div>

      <button
        class="inline-flex items-center justify-center rounded-md bg-foreground text-background h-10 w-10 hover:bg-foreground/80 flex-shrink-0"
        data-carousel-next
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
    <div class="sr-only">Use left and right arrow keys to navigate between slides.</div>
  </div>
)}

<script>
  document.querySelectorAll<HTMLElement>('[data-component="ImageCarouselPreviewBelow"]').forEach((container) => {
    const items = Array.from(container.querySelectorAll<HTMLElement>('[data-carousel-item]'));
    const links = Array.from(container.querySelectorAll<HTMLElement>('[data-carousel-link]'));
    const thumbs = Array.from(container.querySelectorAll<HTMLElement>('[data-thumb-item]'));
    const thumbTrack = container.querySelector<HTMLElement>('[data-thumb-track]');
    const liveRegion = container.querySelector<HTMLElement>('[data-carousel-live]');
    const prevBtn = container.querySelector<HTMLElement>('[data-carousel-prev]');
    const nextBtn = container.querySelector<HTMLElement>('[data-carousel-next]');

    if (!items.length) return;

    let current = 0;
    const total = items.length;

    function wrapIndex(i: number) { return ((i % total) + total) % total; }

    function updateSlide(index: number) {
      current = wrapIndex(index);

      // Update main slides
      items.forEach((el, i) => {
        const isActive = i === current;
        el.classList.toggle('opacity-100', isActive);
        el.classList.toggle('opacity-0', !isActive);
        el.classList.toggle('pointer-events-none', !isActive);
        el.classList.toggle('relative', isActive);
        el.classList.toggle('absolute', !isActive);
        el.classList.toggle('inset-0', !isActive);
        el.setAttribute('tabindex', isActive ? '0' : '-1');
      });

      // Update links
      links.forEach((link, i) => {
        link.classList.toggle('hidden', i !== current);
      });

      // Update thumbnails
      thumbs.forEach((thumb, i) => {
        const isActive = i === current;
        thumb.classList.toggle('border-foreground', isActive);
        thumb.classList.toggle('border-transparent', !isActive);
        thumb.setAttribute('aria-current', isActive ? 'true' : 'false');
      });

      // Scroll thumbnail track to keep current visible
      if (thumbTrack && thumbs[current]) {
        const thumbWidth = thumbs[current].offsetWidth + 8; // gap
        const offset = current * thumbWidth;
        thumbTrack.style.transform = `translateX(${-Math.max(0, offset - thumbWidth)}px)`;
      }

      if (liveRegion) {
        liveRegion.textContent = `Showing slide ${current + 1} of ${total}`;
      }
    }

    prevBtn?.addEventListener('click', () => updateSlide(current - 1));
    nextBtn?.addEventListener('click', () => updateSlide(current + 1));

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const idx = parseInt(thumb.getAttribute('data-thumb-index') || '0', 10);
        updateSlide(idx);
      });
    });

    container.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); updateSlide(current - 1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); updateSlide(current + 1); }
    });
  });
</script>
