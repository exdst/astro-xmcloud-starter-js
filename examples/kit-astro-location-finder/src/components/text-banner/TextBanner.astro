---
import type { ComponentProps } from "@/lib/component-props";
import TextBannerDefault from "./TextBannerDefault.astro";
import TextBanner01 from "./TextBanner01.astro";
import TextBanner02 from "./TextBanner02.astro";
import TextBannerTextTop from "./TextBannerTextTop.astro";
import TextBannerBlueTitleRight from "./TextBannerBlueTitleRight.astro";

const { params } = Astro.props as ComponentProps;
const variant = params?.FieldNames || 'Default';

const variants: Record<string, any> = {
  Default: TextBannerDefault,
  TextBanner01: TextBanner01,
  TextBanner02: TextBanner02,
  TextTop: TextBannerTextTop,
  BlueTitleRight: TextBannerBlueTitleRight,
};

const Component = variants[variant] || TextBannerDefault;
---
<Component {...Astro.props} />
