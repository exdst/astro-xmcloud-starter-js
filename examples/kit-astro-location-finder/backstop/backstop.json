{
  "id": "astro-vs-nextjs",
  "viewports": [
    { "label": "desktop", "width": 1920, "height": 1080 },
    { "label": "tablet", "width": 768, "height": 1024 },
    { "label": "mobile", "width": 375, "height": 812 }
  ],
  "scenarios": [
    {
      "label": "Homepage",
      "url": "http://localhost:3005/",
      "referenceUrl": "http://localhost:3004/",
      "delay": 5000,
      "readySelector": "body",
      "postInteractionWait": 3000,
      "misMatchThreshold": 0.1
    },
    {
      "label": "Products - Aero",
      "url": "http://localhost:3005/Products/Aero",
      "referenceUrl": "http://localhost:3004/Products/Aero",
      "delay": 5000,
      "readySelector": "body",
      "postInteractionWait": 3000,
      "misMatchThreshold": 0.1
    },
    {
      "label": "Products - Nexa",
      "url": "http://localhost:3005/Products/Nexa",
      "referenceUrl": "http://localhost:3004/Products/Nexa",
      "delay": 5000,
      "readySelector": "body",
      "postInteractionWait": 3000,
      "misMatchThreshold": 0.1
    },
    {
      "label": "Products - Terra",
      "url": "http://localhost:3005/Products/Terra",
      "referenceUrl": "http://localhost:3004/Products/Terra",
      "delay": 5000,
      "readySelector": "body",
      "postInteractionWait": 3000,
      "misMatchThreshold": 0.1
    },
    {
      "label": "Test Drive",
      "url": "http://localhost:3005/Test-Drive",
      "referenceUrl": "http://localhost:3004/Test-Drive",
      "delay": 5000,
      "readySelector": "body",
      "postInteractionWait": 3000,
      "misMatchThreshold": 0.1
    }
  ],
  "paths": {
    "bitmaps_reference": "backstop_data/bitmaps_reference",
    "bitmaps_test": "backstop_data/bitmaps_test",
    "engine_scripts": "backstop_data/engine_scripts",
    "html_report": "backstop_data/html_report",
    "ci_report": "backstop_data/ci_report"
  },
  "onBeforeScript": "puppet/onBefore.js",
  "onReadyScript": "puppet/onReady.js",
  "engine": "puppeteer",
  "engineOptions": {
    "args": ["--no-sandbox"]
  },
  "report": ["browser"],
  "asyncCaptureLimit": 1,
  "asyncCompareLimit": 50,
  "debug": false,
  "debugWindow": false,
  "requireSameDimensions": true,
  "resembleOutputOptions": {
    "ignoreAntialiasing": true
  }
}
